<view class="page {{themeClass}}" style="{{themeStyle}}">
  <view class="header">
    <view>
      <view class="eyebrow">CUSTOM STUDIO</view>
      <view class="brand">非常智造</view>
    </view>
    <button class="header-mark" bindtap="goProfile" aria-label="进入我的页面">
      <image wx:if="{{headerAvatar}}" class="header-avatar" src="{{headerAvatar}}" mode="aspectFill" />
      <text wx:else>{{headerMarkText}}</text>
    </button>
  </view>

  <view wx:if="{{bannerLoading && !banners.length}}" class="hero-swiper hero-skeleton">
    <view class="hero-placeholder"></view>
  </view>

  <swiper wx:elif="{{banners.length}}" class="hero-swiper" autoplay circular interval="3600" duration="650" indicator-dots indicator-color="rgba(255,255,255,.45)" indicator-active-color="#ffffff">
    <swiper-item wx:for="{{banners}}" wx:key="title">
      <view class="hero hero-{{item.theme}}" style="{{bannerStyle}}" bindtap="openBanner" data-index="{{index}}">
        <view class="hero-placeholder {{item.loaded ? 'is-hidden' : ''}}"></view>
        <image wx:if="{{item.finalImageUrl || item.displayImage || item.bannerUrl || item.optimizedUrl || item.imageUrl}}" class="hero-image {{item.loaded ? 'is-loaded' : ''}}" style="{{bannerImageStyle}}" src="{{item.finalImageUrl || item.displayImage || item.bannerUrl || item.optimizedUrl || item.imageUrl}}" mode="aspectFill" lazy-load="{{index > 0}}" data-index="{{index}}" bindload="onBannerLoad" binderror="onBannerError" />
        <view wx:if="{{item.imageUrl}}" class="hero-mask" style="{{bannerOverlayStyle}}"></view>
        <view class="hero-copy">
          <view class="hero-tag">{{item.tag}}</view>
          <view class="hero-title">{{item.title}}</view>
          <view class="hero-desc" style="{{mutedTextStyle}}">{{item.desc}}</view>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view wx:else class="hero-swiper hero-skeleton">
    <view class="hero-placeholder"></view>
  </view>

  <view class="search-panel">
    <view class="search-box">
      <text class="search-icon">⌕</text>
      <input class="search-input" value="{{searchKeyword}}" placeholder="搜索商品、类目、标签" placeholder-class="search-placeholder" bindinput="onSearchInput" confirm-type="search" />
      <button wx:if="{{searchKeyword}}" class="search-clear" style="{{primaryButtonStyle}}" bindtap="clearSearch">×</button>
    </view>
  </view>

  <view wx:if="{{showSearchResults}}" class="search-results">
    <view class="search-head">
      <view class="search-title">搜索结果</view>
      <view class="search-count">{{searchProducts.length}} 件商品</view>
    </view>
    <view wx:if="{{searchProducts.length}}" class="product-grid search-product-list">
      <view class="product-card" style="{{cardStyle}}" wx:for="{{searchProducts}}" wx:key="id" bindtap="openProduct" data-id="{{item.id}}">
        <view class="product-cover cover-{{item.cover}}">
          <image wx:if="{{item.displayImage || item.imageUrl}}" class="product-image" src="{{item.displayImage || item.imageUrl}}" mode="aspectFill" lazy-load />
          <view wx:if="{{item.displayTag}}" class="product-badge badge-{{item.badge}}">{{item.displayTag}}</view>
        </view>
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-intro" style="{{mutedTextStyle}}">{{item.intro}}</view>
          <view class="product-bottom">
            <view class="price" style="{{priceStyle}}">¥{{item.price}}</view>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="search-empty">
      <view>暂无相关商品，联系客服定制</view>
      <button class="search-service" style="{{primaryButtonStyle}}" open-type="contact">联系客服</button>
    </view>
  </view>

  <view class="entry-grid">
    <button class="entry-card" style="{{cardStyle}}" wx:for="{{homeEntries}}" wx:key="name" bindtap="openHomeEntry" data-index="{{index}}">
      <view class="entry-icon" style="{{iconBadgeStyle}}">
        <image wx:if="{{item.thumbUrl || item.imageUrl}}" class="entry-image" src="{{item.thumbUrl || item.imageUrl}}" mode="aspectFit" lazy-load />
        <text wx:else>{{item.icon}}</text>
      </view>
      <view class="entry-copy">
        <view class="entry-name">{{item.name}}</view>
        <view class="entry-desc" style="{{mutedTextStyle}}">{{item.desc}}</view>
      </view>
    </button>
  </view>

  <view class="trust-strip">
    <view class="trust-item" wx:for="{{trustTags}}" wx:key="text">
      <view class="trust-icon" style="{{iconBadgeStyle}}">{{item.icon}}</view>
      <view class="trust-text">{{item.text}}</view>
    </view>
  </view>

  <view wx:if="{{products.length}}" class="section-head">
    <view>
      <view class="section-title">热门推荐商品</view>
      <view class="section-subtitle" style="{{mutedTextStyle}}">{{sectionSubtitle}}</view>
    </view>
    <view class="section-more">精选</view>
  </view>

  <view wx:if="{{products.length}}" class="product-grid">
    <view class="product-card" style="{{cardStyle}}" wx:for="{{products}}" wx:key="id" bindtap="openProduct" data-id="{{item.id}}">
      <view class="product-cover cover-{{item.cover}}">
        <image wx:if="{{item.displayImage || item.imageUrl}}" class="product-image" src="{{item.displayImage || item.imageUrl}}" mode="aspectFill" lazy-load />
        <view wx:if="{{item.displayTag}}" class="product-badge badge-{{item.badge}}">{{item.displayTag}}</view>
      </view>
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-intro" style="{{mutedTextStyle}}">{{item.intro}}</view>
        <view class="product-bottom">
          <view class="price" style="{{priceStyle}}">¥{{item.price}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{hotProducts.length}}" class="section-head">
    <view>
      <view class="section-title">爆款专区</view>
      <view class="section-subtitle" style="{{mutedTextStyle}}">高人气单品，适合送礼和自用收藏</view>
    </view>
    <view class="section-more">热卖</view>
  </view>

  <view wx:if="{{hotProducts.length}}" class="product-grid burst-grid">
    <view class="product-card" style="{{cardStyle}}" wx:for="{{hotProducts}}" wx:key="id" bindtap="openProduct" data-id="{{item.id}}">
      <view class="product-cover cover-{{item.cover}}">
        <image wx:if="{{item.displayImage || item.imageUrl}}" class="product-image" src="{{item.displayImage || item.imageUrl}}" mode="aspectFill" lazy-load />
        <view wx:if="{{item.displayTag}}" class="product-badge badge-{{item.badge}}">{{item.displayTag}}</view>
      </view>
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-intro" style="{{mutedTextStyle}}">{{item.intro}}</view>
        <view class="product-bottom">
          <view class="price" style="{{priceStyle}}">¥{{item.price}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="contact-panel" style="{{cardStyle}}">
    <view class="contact-copy">
      <view class="contact-title">定制前有疑问？</view>
      <view class="contact-subtitle" style="{{mutedTextStyle}}">联系客服确认图片、尺寸和交付时间</view>
    </view>
    <button class="contact-btn" style="{{primaryButtonStyle}}" open-type="contact">联系客服</button>
  </view>
</view>
