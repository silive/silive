.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 44rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 0%, rgba(255, 176, 166, .26), transparent 28%),
    linear-gradient(180deg, #FFF9F3 0%, #ffffff 46%, #FFF3E8 100%);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 10rpx 0 26rpx;
}

.eyebrow {
  color: #E94B00;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  font-weight: 700;
}

.brand {
  margin-top: 8rpx;
  color: #211f1e;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.header-mark {
  width: 64rpx;
  height: 64rpx;
  min-width: 64rpx;
  max-width: 64rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  border: 0;
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #FFFFFF;
  flex: 0 0 64rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 30rpx rgba(32, 32, 32, .18);
  overflow: hidden;
  line-height: 64rpx;
  box-sizing: border-box;
}

.header-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.header-mark::after {
  border: 0;
}

.hero-swiper {
  height: 304rpx;
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 22rpx 52rpx rgba(63, 45, 42, .14);
}

.hero-skeleton {
  position: relative;
  background: linear-gradient(135deg, #f5f7fb 0%, #FFF3E8 52%, #f8fbff 100%);
}

.hero {
  position: relative;
  height: 304rpx;
  padding: 36rpx;
  box-sizing: border-box;
  overflow: hidden;
  background: linear-gradient(135deg, #f5f7fb 0%, #FFF3E8 100%);
}

.hero-image,
.hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-placeholder {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #f5f7fb 0%, #FFF3E8 52%, #f8fbff 100%);
  opacity: 1;
  transition: opacity .22s ease;
  z-index: 0;
  pointer-events: none;
}

.hero-placeholder::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, .56), transparent);
  animation: bannerShimmer 1.6s ease-in-out infinite;
}

.hero-placeholder.is-hidden {
  opacity: 0;
}

.hero-image {
  opacity: 1;
  transition: opacity .22s ease;
  background: #f5f7fb;
  z-index: 1;
}

.hero-image.is-loaded {
  opacity: 1;
}

@keyframes bannerShimmer {
  to { transform: translateX(100%); }
}

.hero-mask {
  left: 0;
  right: auto;
  width: 58%;
  background: linear-gradient(90deg, rgba(15, 23, 42, .28), rgba(15, 23, 42, .10), transparent);
  pointer-events: none;
  z-index: 2;
}

.hero-print {
  background: linear-gradient(135deg, #FF7A00 0%, #FF5A00 54%, #FFD21A 100%);
}

.hero-laser {
  background: linear-gradient(135deg, #FF7A00 0%, #FFD21A 56%, #FFD21A 100%);
}

.hero-studio {
  background: linear-gradient(135deg, #FF7A00 0%, #FF5A00 52%, #FFD21A 100%);
}

.hero-copy {
  position: relative;
  z-index: 3;
  width: 470rpx;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .16);
  color: rgba(255, 255, 255, .88);
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 20rpx;
  color: #ffffff;
  font-size: 40rpx;
  line-height: 1.18;
  font-weight: 800;
  letter-spacing: 0;
}

.hero-desc {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, .78);
  font-size: 24rpx;
  line-height: 1.5;
}

.search-panel {
  margin-top: 20rpx;
}

.search-box {
  height: 78rpx;
  padding: 0 18rpx 0 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 12rpx 30rpx rgba(83, 69, 64, .07);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-icon {
  color: #E94B00;
  font-size: 28rpx;
  font-weight: 850;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  color: #1F2933;
  font-size: 25rpx;
  font-weight: 700;
}

.search-placeholder {
  color: #9CA3AF;
  font-weight: 500;
}

.search-clear {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #FFF9F3;
  color: #E94B00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.search-results {
  margin-top: 18rpx;
}

.search-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.search-title {
  color: #1F2933;
  font-size: 28rpx;
  font-weight: 850;
}

.search-count {
  color: #E94B00;
  font-size: 22rpx;
  font-weight: 800;
}

.search-product-list {
  margin-bottom: 10rpx;
}

.search-empty {
  padding: 42rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .9);
  color: #6b7280;
  text-align: center;
  font-size: 25rpx;
  box-shadow: 0 12rpx 30rpx rgba(83, 69, 64, .06);
}

.search-service {
  width: 180rpx;
  height: 58rpx;
  margin: 22rpx auto 0;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1;
}

.search-service::after,
.contact-btn::after {
  border: 0;
}

.hero-visual {
  position: absolute;
  right: 20rpx;
  top: 30rpx;
  width: 250rpx;
  height: 250rpx;
}

.cube {
  position: absolute;
  border-radius: 24rpx;
  transform: rotate(18deg) skew(-8deg);
  box-shadow: inset -18rpx -18rpx 28rpx rgba(0, 0, 0, .12), 0 22rpx 48rpx rgba(0, 0, 0, .18);
}

.cube-one {
  right: 34rpx;
  top: 28rpx;
  width: 130rpx;
  height: 130rpx;
  background: linear-gradient(135deg, rgba(255,255,255,.94), rgba(220,235,255,.72));
}

.cube-two {
  right: 104rpx;
  top: 136rpx;
  width: 74rpx;
  height: 74rpx;
  background: linear-gradient(135deg, rgba(238,246,255,.92), rgba(255,255,255,.54));
}

.laser-line {
  position: absolute;
  right: 16rpx;
  top: 114rpx;
  width: 226rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, transparent, #ffffff, #FFD21A);
  transform: rotate(-28deg);
  box-shadow: 0 0 18rpx rgba(246, 200, 106, .86);
}

.spark {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #e8f3ff;
  box-shadow: 0 0 22rpx rgba(255, 247, 201, .94);
}

.spark-one {
  right: 188rpx;
  top: 64rpx;
}

.spark-two {
  right: 54rpx;
  top: 194rpx;
}

.trust-strip {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 20rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid rgba(185, 111, 103, .12);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, .72);
  box-shadow: 0 12rpx 30rpx rgba(83, 69, 64, .06);
  backdrop-filter: blur(18rpx);
}

.trust-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.trust-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF3E8, #FFF3E8);
  color: #E94B00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 850;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, .82);
}

.trust-text {
  width: 100%;
  color: #6B7280;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.28;
  text-align: center;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.entry-card {
  min-height: 150rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 14rpx 34rpx rgba(83, 69, 64, .07);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  text-align: left;
  box-sizing: border-box;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  min-width: 96rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFF3E8;
  color: #FF5A00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 950;
}

.entry-image {
  width: 100%;
  height: 100%;
}

.entry-copy {
  flex: 1;
  min-width: 0;
}

.entry-name {
  color: #1F2933;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 950;
}

.entry-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 21rpx;
  line-height: 1.35;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 28rpx;
}

.category {
  height: 154rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, .88);
  box-shadow: 0 12rpx 34rpx rgba(83, 69, 64, .08);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  padding: 0 28rpx;
  box-sizing: border-box;
  text-align: left;
}

.category-icon {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #211f1e;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.category-name {
  margin-top: 14rpx;
  color: #1F2933;
  font-size: 28rpx;
  font-weight: 800;
}

.category-desc {
  margin-top: 6rpx;
  color: #918985;
  font-size: 22rpx;
  line-height: 1.3;
  white-space: pre-line;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 190rpx;
  gap: 18rpx;
  margin-top: 28rpx;
}

.upload-btn,
.service-btn {
  min-height: 112rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.upload-btn {
  padding: 0 26rpx;
  gap: 20rpx;
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(32, 32, 32, .18);
  text-align: left;
}

.action-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #FFD21A;
  color: #1F2933;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
}

.action-title {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.action-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, .62);
  font-size: 21rpx;
}

.service-btn {
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
  background: #FFF3E8;
  color: #24302d;
  font-size: 24rpx;
  font-weight: 800;
}

.service-icon {
  font-size: 34rpx;
}

.case-line {
  margin-top: 38rpx;
  color: #E94B00;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 42rpx 0 20rpx;
}

.section-title {
  color: #1F2933;
  font-size: 34rpx;
  font-weight: 850;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #9a918d;
  font-size: 22rpx;
}

.section-more {
  color: #E94B00;
  font-size: 24rpx;
  font-weight: 800;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.product-card {
  min-width: 0;
  padding: 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .94);
  box-shadow: 0 12rpx 30rpx rgba(255, 106, 0, .06);
  box-sizing: border-box;
}

.product-cover {
  position: relative;
  width: 100%;
  height: 260rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.product-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cover-keyring {
  background:
    radial-gradient(circle at 58% 42%, #ffffff 0 15%, transparent 16%),
    linear-gradient(135deg, #FFD21A, #FF5A00);
}

.cover-pet {
  background:
    radial-gradient(circle at 48% 38%, #FFF3E8 0 18%, transparent 19%),
    linear-gradient(135deg, #FFF3E8, #FF5A00);
}

.cover-wood {
  background:
    repeating-linear-gradient(35deg, rgba(255,255,255,.18) 0 10rpx, transparent 10rpx 22rpx),
    linear-gradient(135deg, #FF5A00, #FF5A00);
}

.product-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  height: 34rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .9);
  color: #FF5A00;
  font-size: 18rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
}

.badge-new {
  background: rgba(255, 255, 255, .92);
  color: #E94B00;
}

.badge-hot {
  background: #FFF3E8;
  color: #FF5A00;
}

.badge-best {
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #FFFFFF;
}

.product-info {
  min-width: 0;
  padding: 16rpx 2rpx 2rpx;
  display: flex;
  flex-direction: column;
}

.product-name {
  color: #1F2933;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.32;
  min-height: 40rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-intro {
  margin-top: 8rpx;
  color: #6B7280;
  font-size: 23rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-proof {
  align-self: flex-start;
  margin-top: 12rpx;
  height: 34rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #FFF9F3;
  color: #E94B00;
  display: flex;
  align-items: center;
  font-size: 19rpx;
  font-weight: 800;
}

.product-bottom {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price {
  color: #FF5A00;
  font-size: 34rpx;
  font-weight: 850;
}

.burst-grid {
  margin-top: 2rpx;
}

.review-list {
  display: grid;
  gap: 16rpx;
}

.review-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.review-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.review-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 850;
}

.review-name {
  color: #1F2933;
  font-size: 26rpx;
  font-weight: 850;
}

.review-product {
  margin-top: 6rpx;
  color: #9a918d;
  font-size: 21rpx;
}

.review-text {
  margin-top: 18rpx;
  color: #6B7280;
  font-size: 25rpx;
  line-height: 1.55;
}

.contact-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 42rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #FFFFFF;
  box-shadow: 0 20rpx 48rpx rgba(32, 32, 32, .18);
}

.contact-title {
  font-size: 31rpx;
  font-weight: 850;
}

.contact-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 246, 239, .68);
  font-size: 22rpx;
  line-height: 1.4;
}

.contact-btn {
  flex: 0 0 184rpx;
  height: 68rpx;
  border-radius: 999rpx;
  background: #f8fbff;
  color: #1F2933;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 850;
}

/* Youth brand visual refresh */
.page {
  padding: 30rpx 28rpx 52rpx;
  background:
    radial-gradient(circle at 8% 2%, rgba(255,106,0,.14), transparent 28%),
    radial-gradient(circle at 96% 18%, rgba(255,210,26,.14), transparent 30%),
    linear-gradient(180deg, #FFF9F3 0%, #ffffff 44%, #ffffff 100%);
  animation: pageFade .36s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.eyebrow,
.section-more,
.search-count {
  color: #FFD21A;
  letter-spacing: 1rpx;
}

.brand {
  color: #1f1d20;
  font-size: 46rpx;
  font-weight: 950;
}

.header-mark {
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #fff;
  box-shadow: 0 18rpx 36rpx rgba(255,106,0,.18);
}

.hero-swiper {
  height: 330rpx;
  border-radius: 34rpx;
  box-shadow: 0 28rpx 68rpx rgba(255,106,0,.16);
}

.hero {
  height: 330rpx;
  padding: 38rpx;
}

.hero-mask {
  left: 0;
  right: auto;
  width: 58%;
  background: linear-gradient(90deg, rgba(15, 23, 42, .26), rgba(15, 23, 42, .08), transparent);
  pointer-events: none;
}

.hero-print,
.hero-laser,
.hero-studio {
  background: linear-gradient(135deg, #f5f7fb 0%, #FFF3E8 52%, #f8fbff 100%);
}

.hero-tag {
  background: rgba(255, 255, 255, .22);
  color: #fff;
  font-weight: 850;
}

.hero-title {
  font-size: 43rpx;
  font-weight: 950;
}

.hero-desc {
  color: rgba(255, 255, 255, .86);
}

.search-box,
.trust-strip,
.entry-card,
.product-card,
.review-card,
.search-empty {
  border: 1rpx solid rgba(255,106,0,.14);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .84);
  box-shadow: 0 18rpx 48rpx rgba(255,106,0,.10);
  backdrop-filter: blur(18rpx);
}

.search-box {
  height: 84rpx;
  border-radius: 999rpx;
}

.search-icon {
  color: #FFD21A;
}

.entry-grid {
  gap: 20rpx;
}

.entry-card {
  min-height: 150rpx;
  padding: 20rpx 22rpx;
}

.entry-card:active,
.product-card:active,
.review-card:active {
  transform: translateY(-2rpx) scale(.992);
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  min-width: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FFF3E8, #FFF3E8);
  color: #FF5A00;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, .9);
}

.entry-name,
.section-title,
.product-name,
.review-name {
  color: #1F2933;
  font-weight: 950;
}

.entry-desc,
.section-subtitle,
.product-intro,
.review-product,
.review-text,
.trust-text {
  color: #6b7280;
}

.trust-strip {
  padding: 18rpx 12rpx;
  border-radius: 24rpx;
}

.trust-icon {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #fff;
  box-shadow: 0 10rpx 22rpx rgba(255,106,0,.14);
}

.cover-keyring,
.cover-pet,
.cover-wood {
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .75), transparent 22%),
    linear-gradient(135deg, #FFF0DB, #FFD21A 52%, #FF5A00);
}

.product-badge,
.badge-new,
.badge-hot {
  background: rgba(255, 255, 255, .92);
  color: #FF5A00;
}

.badge-best {
  background: linear-gradient(135deg, #FF7A00, #FFD21A);
  color: #fff;
}

.product-proof {
  background: #FFF3E8;
  color: #FF5A00;
}

.price {
  color: #FF4D00;
  font-weight: 950;
}

.search-service,
.contact-btn {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(255,106,0,.14);
}

.review-avatar {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  box-shadow: 0 10rpx 24rpx rgba(255,106,0,.14);
}

.contact-panel {
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 88% 0%, rgba(255, 255, 255, .24), transparent 30%),
    linear-gradient(135deg, #FF7A00 0%, #FFD21A 100%);
  box-shadow: 0 24rpx 56rpx rgba(255,106,0,.13);
}

/* Runtime theme variables */
.page {
  background:
    radial-gradient(circle at 8% 2%, var(--soft-color, rgba(255,106,0,.14)), transparent 28%),
    radial-gradient(circle at 96% 18%, var(--accent-color, rgba(255,210,26,.14)), transparent 30%),
    linear-gradient(180deg, var(--page-top-color, #FFF9F3) 0%, #ffffff 44%, var(--page-bottom-color, #ffffff) 100%);
}

.header-mark,
.search-service,
.contact-btn,
.trust-icon,
.review-avatar {
  background: linear-gradient(135deg, var(--button-start, #FF7A00), var(--button-end, #FF4D00));
}

.search-box,
.trust-strip,
.entry-card,
.product-card,
.review-card,
.search-empty {
  border-radius: var(--card-radius, 28rpx);
  background: var(--card-color, rgba(255,255,255,.86));
  box-shadow: 0 18rpx 48rpx var(--theme-shadow, rgba(255,106,0,.10));
}

.eyebrow,
.section-more,
.search-icon,
.search-count,
.product-proof,
.entry-icon {
  color: var(--accent-color, #FF5A00);
}

.brand,
.section-title,
.entry-name,
.product-name,
.review-name {
  color: var(--text-color, #1F2933);
}

.section-subtitle,
.entry-desc,
.product-intro,
.review-product,
.review-text,
.trust-text {
  color: var(--muted-color, #6b7280);
}

.price {
  color: var(--price-color, #FF4D00);
}

.product-proof {
  background: var(--soft-color, #FFF3E8);
}
