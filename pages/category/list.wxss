.page {
  min-height: 100vh;
  padding: 30rpx 28rpx calc(190rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #FFF9F3 0%, #ffffff 52%, #FFF3E8 100%);
}

.title-block {
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #E94B00;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  font-weight: 800;
}

.title {
  margin-top: 8rpx;
  color: #1F2933;
  font-size: 42rpx;
  font-weight: 850;
}

.subtitle {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.search-box {
  height: 78rpx;
  margin-bottom: 20rpx;
  padding: 0 18rpx 0 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 12rpx 30rpx rgba(83, 69, 64, .07);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-icon {
  color: #E94B00;
  font-size: 28rpx;
  font-weight: 850;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  color: #1F2933;
  font-size: 25rpx;
  font-weight: 700;
}

.search-placeholder {
  color: #9CA3AF;
  font-weight: 500;
}

.search-clear {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #FFF9F3;
  color: #E94B00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.subnav {
  width: 100%;
  margin: 0 0 24rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  align-content: flex-start;
}

.subnav-item {
  flex: 0 0 auto;
  width: auto;
  max-width: 640rpx;
  height: 54rpx;
  margin: 0 12rpx 10rpx 0;
  padding: 0 22rpx;
  border: 1rpx solid rgba(36, 33, 32, .08);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .92);
  color: #6B7280;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 54rpx;
  white-space: nowrap;
  box-shadow: 0 8rpx 20rpx rgba(83, 69, 64, .05);
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
}

.subnav-item.active {
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  border-color: #FF5A00;
  color: #FFFFFF;
}

.subnav-item.disabled {
  color: #9CA3AF;
  background: rgba(255, 255, 255, .64);
  border-color: rgba(36, 33, 32, .05);
  box-shadow: none;
}

.subnav-item.active.disabled {
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  border-color: #FF5A00;
  color: #FFFFFF;
}

.subnav-count {
  margin-left: 8rpx;
  color: inherit;
  font-size: 19rpx;
  opacity: .72;
}

.soon-tag {
  height: 30rpx;
  margin-left: 8rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #FFF9F3;
  color: #E94B00;
  display: inline-flex;
  align-items: center;
  font-size: 17rpx;
  font-weight: 850;
}

.subnav-item.active .soon-tag {
  background: rgba(255, 255, 255, .18);
  color: #FFFFFF;
}

.product-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.category-loading {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.loading-card {
  min-height: 408rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .88);
  box-shadow: 0 12rpx 30rpx rgba(255, 106, 0, .06);
  box-sizing: border-box;
}

.loading-cover,
.loading-line {
  background: linear-gradient(90deg, #FFF3E8 0%, #f8fbff 50%, #FFF3E8 100%);
  background-size: 200% 100%;
  animation: loadingShimmer 1.4s ease-in-out infinite;
}

.loading-cover {
  width: 100%;
  height: 260rpx;
  border-radius: 20rpx;
}

.loading-lines {
  padding: 18rpx 0 0;
}

.loading-line {
  height: 24rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
}

.loading-line.wide {
  width: 76%;
}

.loading-line.short {
  width: 42%;
}

@keyframes loadingShimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.product-card {
  min-width: 0;
  min-height: 424rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(255, 106, 0, .06);
  box-sizing: border-box;
  overflow: hidden;
}

.product-cover {
  position: relative;
  width: 100%;
  height: 260rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f5f7fb;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  height: 34rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .9);
  color: #FF5A00;
  font-size: 18rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
}

.badge-hot {
  background: #FFF3E8;
  color: #FF5A00;
}

.badge-best {
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #FFFFFF;
}

.product-info {
  min-width: 0;
  padding: 18rpx 2rpx 0;
  display: flex;
  flex-direction: column;
}

.product-name {
  color: #1F2933;
  font-size: 30rpx;
  font-weight: 850;
  line-height: 1.32;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-intro {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.35;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.product-bottom {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price {
  color: #FF4D00;
  font-size: 32rpx;
  font-weight: 850;
}

.buy-btn {
  width: 96rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 800;
}

.product-actions {
  flex: 1;
  min-width: 0;
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  flex-wrap: nowrap;
}

.cart-btn {
  width: 112rpx;
  min-width: 0;
  height: 52rpx;
  padding: 0;
  border-radius: 999rpx;
  border: 1rpx solid #FFD9BF;
  background: #ffffff;
  color: #FF5A00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 850;
  box-sizing: border-box;
}

.cart-btn::after,
.buy-btn::after,
.floating-cart::after,
.empty-btn::after {
  border: 0;
}

.product-actions .buy-btn {
  width: 86rpx;
  flex-shrink: 0;
}

.floating-cart {
  position: fixed;
  right: 32rpx;
  bottom: calc(170rpx + env(safe-area-inset-bottom));
  z-index: 1200;
  width: 96rpx !important;
  height: 96rpx !important;
  min-width: 96rpx !important;
  max-width: 96rpx !important;
  min-height: 96rpx !important;
  max-height: 96rpx !important;
  padding: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 42rpx rgba(255,106,0,.24);
  box-sizing: border-box;
  line-height: 1;
  overflow: visible;
}

.floating-cart-icon {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 950;
  line-height: 1;
  display: block;
}

.floating-cart-badge {
  position: absolute;
  top: -8rpx;
  right: -6rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #FF4D00;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 34rpx;
  box-sizing: border-box;
}

.empty {
  margin-top: 80rpx;
  color: #6b7280;
  text-align: center;
  font-size: 26rpx;
}

.empty-card {
  margin-top: 42rpx;
  padding: 46rpx 34rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .94);
  box-shadow: 0 16rpx 42rpx rgba(83, 69, 64, .08);
  text-align: center;
}

.empty-mark {
  width: 82rpx;
  height: 82rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.empty-title {
  color: #1F2933;
  font-size: 34rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.empty-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 30rpx;
}

.empty-btn {
  height: 74rpx;
  border-radius: 999rpx;
  background: #FFF9F3;
  color: #E94B00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 850;
}

.empty-btn.dark {
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #ffffff;
}

/* Youth brand visual refresh */
.page {
  background:
    radial-gradient(circle at 10% 0%, rgba(255, 126, 159, .18), transparent 28%),
    linear-gradient(180deg, #FFF9F3 0%, #ffffff 48%, #ffffff 100%);
  animation: pageFade .34s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.eyebrow {
  color: #FFD21A;
}

.title,
.product-name,
.empty-title {
  color: #1F2933;
  font-weight: 950;
}

.subtitle,
.product-intro,
.empty-desc {
  color: #6b7280;
}

.search-box,
.product-card,
.empty-card {
  border: 1rpx solid rgba(255,106,0,.14);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .86);
  box-shadow: 0 18rpx 48rpx rgba(255,106,0,.10);
  backdrop-filter: blur(18rpx);
}

.search-box {
  height: 84rpx;
  border-radius: 999rpx;
}

.search-icon {
  color: #FFD21A;
}

.subnav-item {
  height: 58rpx;
  padding: 0 24rpx;
  border-color: rgba(255,106,0,.16);
  background: rgba(255, 255, 255, .82);
  color: #7f7476;
  box-shadow: 0 10rpx 24rpx rgba(255,106,0,.08);
}

.subnav-item.active,
.subnav-item.active.disabled {
  border-color: transparent;
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(255,106,0,.14);
}

.soon-tag,
.product-proof {
  background: #FFF3E8;
  color: #FF5A00;
}

.product-card {
  min-height: 424rpx;
  padding: 16rpx;
}

.product-cover {
  width: 100%;
  height: 260rpx;
  border-radius: 20rpx;
  background: #f5f7fb;
}

.product-card:active {
  transform: translateY(-2rpx) scale(.992);
}

.product-badge,
.badge-hot {
  background: rgba(255, 255, 255, .92);
  color: #FF5A00;
}

.badge-best {
  background: linear-gradient(135deg, #FF7A00, #FFD21A);
}

.price {
  color: #FF4D00;
  font-weight: 950;
}

.buy-btn,
.empty-btn.dark {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  box-shadow: 0 14rpx 30rpx rgba(255,106,0,.14);
}

.empty-mark {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
}

.empty-btn {
  background: #FFF3E8;
  color: #FF5A00;
}

/* Runtime theme variables */
.page {
  background: linear-gradient(180deg, var(--page-top-color, #FFF9F3) 0%, #ffffff 48%, var(--page-bottom-color, #ffffff) 100%);
}

.search-box,
.product-card,
.empty-card {
  border-radius: var(--card-radius, 28rpx);
  background: var(--card-color, rgba(255,255,255,.86));
  box-shadow: 0 18rpx 48rpx var(--theme-shadow, rgba(255,106,0,.10));
}

.subnav-item.active,
.subnav-item.active.disabled,
.buy-btn,
.empty-btn.dark,
.empty-mark {
  background: linear-gradient(135deg, var(--button-start, #FF7A00), var(--button-end, #FF4D00));
}

.eyebrow,
.search-icon,
.product-proof,
.soon-tag,
.empty-btn {
  color: var(--accent-color, #FF5A00);
}

.title,
.product-name,
.empty-title {
  color: var(--text-color, #1F2933);
}

.subtitle,
.product-intro,
.empty-desc {
  color: var(--muted-color, #6b7280);
}

.price {
  color: var(--price-color, #FF4D00);
}

.product-proof,
.soon-tag,
.empty-btn {
  background: var(--soft-color, #FFF3E8);
}
