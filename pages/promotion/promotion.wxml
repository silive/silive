<view class="page {{themeClass}}" style="{{themeStyle}}">
  <view class="hero-card">
    <view>
      <view class="eyebrow">PROMOTION</view>
      <view class="title">把喜欢的礼物店分享给朋友</view>
      <view class="subtitle">好友也可能刚好需要</view>
      <view class="hero-note">朋友完成支付后可获得推广奖励</view>
    </view>
  </view>

  <view class="wallet-grid">
    <view class="wallet dark">
      <view class="wallet-label">本次预计到账</view>
      <view class="wallet-value">¥{{profile.actualPayable || '0.00'}}</view>
    </view>
    <view class="wallet">
      <view class="wallet-label">当前待结算</view>
      <view class="wallet-value">¥{{profile.payableTotal || '0.00'}}</view>
    </view>
    <view class="wallet">
      <view class="wallet-label">当前退款扣回</view>
      <view class="wallet-value">¥{{profile.chargebackTotal || '0.00'}}</view>
    </view>
    <view class="wallet">
      <view class="wallet-label">累计已结算</view>
      <view class="wallet-value">¥{{profile.settledTotal || '0.00'}}</view>
    </view>
  </view>
  <view class="panel">
    <view class="record-desc">推广奖励由平台人工审核后结算。若订单退款，相关奖励会进入退款扣回，并在后续结算中抵扣。</view>
    <view wx:if="{{profile.remainingChargeback && profile.remainingChargeback !== '0.00'}}" class="record-desc">仍有 ¥{{profile.remainingChargeback}} 待后续收益抵扣</view>
  </view>

  <view wx:if="{{showInviteTools}}" class="panel">
    <view class="panel-title">邀请二维码</view>
    <view class="qr-box">
      <image wx:if="{{profile.inviteQrUrl}}" class="qr-image" src="{{profile.inviteQrUrl}}" mode="aspectFit" />
      <view wx:else class="qr-inner">{{profile.inviteCode || '专属邀请码'}}</view>
    </view>
    <view class="qr-text">{{profile.inviteQrText}}</view>
    <view class="action-grid">
      <button class="primary-btn" open-type="share">邀请好友逛店</button>
      <button class="light-btn" bindtap="createPoster">生成邀请海报</button>
      <button class="light-btn" bindtap="saveInviteQr">保存推广二维码</button>
    </view>
  </view>

  <view wx:else class="panel">
    <view class="panel-title">分享商品</view>
    <view class="record-desc">进入商品详情页，点击“分享商品”发送给朋友。朋友通过你的商品链接下单并完成支付后，可获得对应推广奖励。</view>
  </view>

  <view class="panel hot-panel" wx:if="{{hotProducts.length}}">
    <view class="panel-title">最近很多人在买</view>
    <view class="hot-grid">
      <view class="hot-card" wx:for="{{hotProducts}}" wx:key="id" bindtap="openProduct" data-id="{{item.id}}">
        <image wx:if="{{item.displayImage}}" class="hot-image" src="{{item.displayImage}}" mode="aspectFill" lazy-load />
        <view wx:else class="hot-image hot-placeholder">非常智造</view>
        <view class="hot-name">{{item.name}}</view>
        <view class="hot-price">¥{{item.price}}</view>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">邀请记录</view>
    <view wx:if="{{invited.length}}">
      <view class="record" wx:for="{{invited}}" wx:key="id">
        <view>
          <view class="record-title">{{item.inviteeName || '用户'}}</view>
          <view class="record-desc">{{item.inviteePhone}}</view>
        </view>
        <view class="pill">推荐好友</view>
      </view>
    </view>
    <view wx:else class="empty">暂无邀请记录</view>
  </view>

  <view class="panel">
    <view class="panel-title">奖励记录</view>
    <view wx:if="{{rewards.length}}">
      <view class="record" wx:for="{{rewards}}" wx:key="id">
        <view>
          <view class="record-title">{{item.productName}}</view>
          <view class="record-desc">{{item.type === 'chargeback' ? '退款冲正' : (item.type === 'adjustment' ? '手动调整' : '推荐奖励')}} · {{item.statusText || item.status}}</view>
        </view>
        <view class="amount">{{item.amountText || ('¥' + item.amount)}}</view>
      </view>
    </view>
    <view wx:else class="empty">暂无奖励记录</view>
  </view>

  <login-sheet
    visible="{{loginVisible}}"
    loading="{{loginLoading}}"
    title="手机号快捷登录"
    desc="我们将申请获取并验证你的手机号，用于订单确认、配送联系、售后服务及账号身份识别。未经你同意，不会用于其他无关用途。"
    confirm-text="手机号快捷登录"
    cancel-text="暂不登录"
    bind:getphonenumber="onLoginPhone"
    bind:close="closeLoginSheet"
  />
</view>
