<view class="page {{themeClass}} has-fixed-actions" style="{{themeStyle}}" wx:if="{{product}}">
  <swiper class="detail-swiper cover-{{product.cover}}" circular indicator-dots="{{product.mediaImages.length > 1 || product.videoUrl}}" indicator-color="rgba(255,255,255,.55)" indicator-active-color="#ffffff">
    <swiper-item wx:if="{{product.videoUrl}}">
      <video class="detail-video" src="{{product.videoUrl}}" controls object-fit="cover" poster="{{product.mediaImages[0] || product.displayImage || product.listImage || product.imageUrl}}"></video>
    </swiper-item>
    <swiper-item wx:for="{{product.mediaImages}}" wx:key="*this">
      <view class="detail-cover">
        <view wx:if="{{index === 0 && !mainImageLoaded}}" class="detail-image-placeholder"></view>
        <image class="detail-image {{index === 0 ? (mainImageLoaded ? 'is-loaded' : 'is-loading') : 'is-loaded'}}" src="{{item}}" mode="aspectFit" lazy-load="{{index > 0}}" data-index="{{index}}" bindload="onMainImageLoad" binderror="onMainImageError" />
      </view>
    </swiper-item>
  </swiper>
  <view wx:if="{{product.displayTag}}" class="detail-badge badge-{{product.badge}}">{{product.displayTag}}</view>

  <view class="detail-main" style="{{cardStyle}}">
    <view class="product-copy">
      <view class="eyebrow">CUSTOM PRODUCT</view>
      <view class="product-title">{{product.name}}</view>
      <view class="product-intro" style="{{mutedTextStyle}}">{{product.intro}}</view>
      <view class="commerce-meta" style="{{mutedTextStyle}}">
        <text>已售 {{product.soldCount}}</text>
        <text>{{product.viewCount}}人浏览</text>
      </view>
      <view wx:if="{{product.categoryText}}" class="category-line" style="{{tagStyle}}">{{product.categoryText}}</view>
    </view>
    <view class="price-box">
      <view class="price" style="{{priceStyle}}">¥{{product.price}}</view>
      <view wx:if="{{product.originalPrice}}" class="original-price">¥{{product.originalPrice}}</view>
      <view class="recommend-tip" style="{{mutedTextStyle}}">{{product.recommendTip}}</view>
    </view>
  </view>

  <view wx:if="{{newcomerBenefits.length}}" class="benefit-strip" style="{{cardStyle}}">
    <view class="benefit-item" wx:for="{{newcomerBenefits}}" wx:key="text">新人首单{{item.text}}</view>
  </view>

  <view wx:if="{{product.isNormalProduct}}" class="normal-action-panel share-only-panel" style="{{cardStyle}}">
    <button class="normal-share-btn" open-type="share">推荐给朋友</button>
  </view>

  <view wx:if="{{!product.isNormalProduct}}" class="top-actions share-only-panel" style="{{cardStyle}}">
    <button class="share-btn" style="{{secondaryButtonStyle}}" open-type="share">推荐给朋友</button>
  </view>

  <view class="panel" style="{{cardStyle}}">
    <view class="panel-title">商品详情</view>
    <view wx:if="{{product.detailText}}" class="detail-text" style="{{mutedTextStyle}}">{{product.detailText}}</view>
    <view class="detail-images" wx:if="{{visibleDetailImages.length}}">
      <image class="detail-long-image" wx:for="{{visibleDetailImages}}" wx:key="*this" src="{{item}}" mode="widthFix" lazy-load />
      <button wx:if="{{product.hasMoreDetailImages && !detailImagesExpanded}}" class="more-detail-btn" bindtap="showMoreDetailImages">查看更多详情</button>
    </view>
  </view>

  <view class="panel note-panel" style="{{cardStyle}}">
    <view class="panel-title">注意事项</view>
    <view class="detail-text" style="{{mutedTextStyle}}">定制商品会在制作前确认方案；图片越清晰，成品效果越稳定。如需加急或特殊尺寸，可先联系客服确认。</view>
  </view>

  <view class="detail-contact-panel" style="{{cardStyle}}">
    <view>
      <view class="contact-title">需要先沟通？</view>
      <view class="contact-subtitle" style="{{mutedTextStyle}}">客服会协助确认商品、配送和售后问题</view>
    </view>
    <button class="detail-contact-btn" open-type="contact">联系客服</button>
  </view>
</view>

<view wx:if="{{product && product.isNormalProduct}}" class="floating-cart" bindtap="openCart" aria-label="购物车">
  <view class="cart-glyph">
    <view class="cart-handle"></view>
    <view class="cart-basket"></view>
    <view class="cart-wheel wheel-left"></view>
    <view class="cart-wheel wheel-right"></view>
  </view>
  <text wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount > 99 ? '99+' : cartCount}}</text>
</view>

<view wx:if="{{product}}" class="fixed-action-bar {{product.isNormalProduct ? '' : 'custom-action-bar'}}">
  <view wx:if="{{product.isNormalProduct}}" class="action-btn-wrap action-cart-wrap">
    <button class="action-btn add-cart-btn" bindtap="addToCart">加入购物车</button>
  </view>
  <view wx:if="{{product.isNormalProduct}}" class="action-btn-wrap action-buy-wrap">
    <button class="action-btn buy-btn" bindtap="buyNow">立即购买</button>
  </view>
  <view wx:else class="action-btn-wrap action-custom-wrap">
    <button class="action-btn buy-btn" bindtap="goCheckout">立即定制</button>
  </view>
</view>

<login-sheet
  visible="{{loginVisible}}"
  loading="{{loginLoading}}"
  title="微信手机号授权登录"
  desc="授权后自动进入确认定制页，手机号会为你预填，可随时修改。"
  confirm-text="授权手机号并继续"
  cancel-text="暂不登录"
  bind:getphonenumber="onCheckoutPhone"
  bind:close="closeLoginPrompt"
/>

<view class="loading" wx:if="{{!product}}">加载中...</view>
