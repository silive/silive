.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FFF9F3 0%, #ffffff 48%, #FFF3E8 100%);
}

.page.has-fixed-actions {
  padding-bottom: 320rpx;
}

.detail-swiper {
  position: relative;
  height: 720rpx;
  border-radius: 26rpx;
  overflow: hidden;
  background: #f5f7fb;
  box-shadow: 0 24rpx 56rpx rgba(63, 45, 42, .16);
  animation: detailFadeUp .34s ease both;
}

.detail-cover {
  position: relative;
  width: 100%;
  height: 720rpx;
  background: #f5f7fb;
}

.detail-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 24rpx;
  background: #f5f7fb;
  transition: opacity .22s ease;
  position: relative;
  z-index: 1;
}

.detail-image.is-loading {
  opacity: 1;
}

.detail-image.is-loaded {
  opacity: 1;
}

.detail-image-placeholder {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #f5f7fb 0%, #FFF3E8 58%, #f8fbff 100%);
  z-index: 0;
  pointer-events: none;
}

.detail-image-placeholder::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, .56), transparent);
  animation: detailShimmer 1.6s ease-in-out infinite;
}

@keyframes detailShimmer {
  to { transform: translateX(100%); }
}

.detail-video {
  width: 100%;
  height: 720rpx;
  display: block;
}

.cover-keyring {
  background: radial-gradient(circle at 58% 42%, #ffffff 0 15%, transparent 16%), linear-gradient(135deg, #FFD21A, #FF5A00);
}

.cover-pet {
  background: radial-gradient(circle at 48% 38%, #FFF3E8 0 18%, transparent 19%), linear-gradient(135deg, #FFF3E8, #FF5A00);
}

.cover-wood {
  background: repeating-linear-gradient(35deg, rgba(255,255,255,.18) 0 10rpx, transparent 10rpx 22rpx), linear-gradient(135deg, #FF5A00, #FF5A00);
}

.detail-badge {
  position: absolute;
  left: 24rpx;
  top: 52rpx;
  z-index: 3;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .9);
  color: #FF5A00;
  font-size: 22rpx;
  font-weight: 850;
  display: flex;
  align-items: center;
}

.badge-new {
  background: rgba(255, 255, 255, .92);
  color: #E94B00;
}

.badge-hot {
  background: #FFF3E8;
  color: #FF5A00;
}

.badge-best {
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #FFFFFF;
}

.detail-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-top: 30rpx;
  padding: 30rpx 28rpx;
  animation: detailFadeUp .38s ease .04s both;
}

.product-copy {
  flex: 1;
  min-width: 0;
}

.eyebrow {
  color: #E94B00;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  font-weight: 800;
}

.product-title {
  margin-top: 8rpx;
  color: #1F2933;
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 950;
}

.product-intro {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.5;
}

.commerce-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.3;
}

.category-line {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  margin-top: 16rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #FFF9F3;
  color: #E94B00;
  font-size: 21rpx;
  font-weight: 800;
}

.price {
  color: #FF4D00;
  font-size: 56rpx;
  line-height: 1.05;
  font-weight: 950;
  white-space: nowrap;
}

.price-box {
  flex: 0 0 auto;
  text-align: right;
  padding-top: 6rpx;
}

.original-price {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 22rpx;
  text-decoration: line-through;
  line-height: 1.2;
}

.recommend-tip {
  width: 210rpx;
  margin-top: 10rpx;
  color: #E94B00;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.35;
}

@keyframes detailFadeUp {
  from {
    opacity: 0;
    transform: translateY(14rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.benefit-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.benefit-item {
  min-height: 38rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #FFF9F3;
  color: #E94B00;
  display: flex;
  align-items: center;
  font-size: 21rpx;
  font-weight: 800;
}

.top-actions {
  display: block;
  margin-top: 26rpx;
}

.primary-btn.compact,
.share-btn {
  height: 82rpx;
  margin-top: 0;
}

.share-btn {
  border-radius: 999rpx;
  background: #FFF9F3;
  color: #E94B00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 850;
}

.floating-cart::after,
.action-btn::after,
.normal-action-btn::after,
.normal-share-btn::after,
.primary-btn::after,
.share-btn::after,
.detail-contact-btn::after {
  border: 0;
}

.normal-action-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, .92);
  border: 1rpx solid rgba(255,106,0,.14);
  box-shadow: 0 18rpx 48rpx rgba(255,106,0,.10);
  animation: detailFadeUp .4s ease .06s both;
  box-sizing: border-box;
}

.share-only-panel {
  padding: 18rpx 22rpx;
}

.normal-action-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.normal-action-wrap {
  height: 88rpx;
  min-width: 0;
}

.normal-cart-action {
  flex: 42 0 0;
}

.normal-buy-action {
  flex: 58 0 0;
}

.normal-action-btn,
.normal-share-btn {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 950;
  line-height: 1;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.normal-add-btn {
  background: #ffffff;
  color: #FF5A00;
  border: 1rpx solid rgba(255,106,0,.32);
}

.normal-buy-btn {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(255,106,0,.22);
}

.normal-share-btn {
  height: 74rpx;
  min-height: 74rpx;
  margin-top: 18rpx;
  background: #f8fbff;
  color: #FF5A00;
  border: 1rpx solid rgba(255,106,0,.20);
  font-size: 25rpx;
  box-shadow: none;
}

.poster-btn {
  margin-top: 16rpx;
}

.floating-cart {
  position: fixed;
  right: 28rpx;
  bottom: 380rpx;
  bottom: calc(380rpx + constant(safe-area-inset-bottom));
  bottom: calc(380rpx + env(safe-area-inset-bottom));
  z-index: 998;
  width: 96rpx;
  height: 96rpx;
  min-width: 96rpx;
  min-height: 96rpx;
  max-width: 96rpx;
  max-height: 96rpx;
  margin: 0;
  padding: 0 !important;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 36rpx rgba(255,106,0,.24);
  line-height: 1;
  box-sizing: border-box;
  overflow: visible;
  flex-shrink: 0;
  pointer-events: auto;
}

.fixed-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 18rpx 28rpx;
  padding-bottom: calc(18rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, .98);
  border-top: 1rpx solid rgba(255,106,0,.12);
  box-shadow: 0 -12rpx 34rpx rgba(31,41,55,.08);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-sizing: border-box;
}

.cart-glyph {
  position: relative;
  width: 42rpx;
  height: 38rpx;
}

.cart-handle {
  position: absolute;
  left: 0;
  top: 2rpx;
  width: 14rpx;
  height: 10rpx;
  border-top: 4rpx solid #ffffff;
  border-left: 4rpx solid #ffffff;
  transform: skewX(-14deg);
  box-sizing: border-box;
}

.cart-basket {
  position: absolute;
  left: 9rpx;
  top: 10rpx;
  width: 30rpx;
  height: 18rpx;
  border: 4rpx solid #ffffff;
  border-top-width: 5rpx;
  border-radius: 4rpx 4rpx 8rpx 8rpx;
  box-sizing: border-box;
}

.cart-wheel {
  position: absolute;
  bottom: 0;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ffffff;
}

.wheel-left {
  left: 14rpx;
}

.wheel-right {
  right: 3rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #FF4D00;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 34rpx;
  box-sizing: border-box;
  white-space: nowrap;
}

.action-btn-wrap {
  min-width: 0;
  height: 88rpx;
}

.action-cart-wrap {
  flex: 42 0 0;
}

.action-buy-wrap {
  flex: 58 0 0;
}

.action-custom-wrap {
  flex: 1;
}

.action-btn {
  width: 100%;
  min-width: 0;
  height: 88rpx;
  min-height: 88rpx;
  max-height: 88rpx;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 950;
  line-height: 1;
  box-sizing: border-box;
  white-space: nowrap;
  flex-shrink: 0;
  overflow: hidden;
}

.add-cart-btn {
  background: #ffffff;
  color: #FF5A00;
  border: 1rpx solid rgba(255,106,0,.32);
}

.buy-btn {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(255,106,0,.24);
}

.panel {
  margin-top: 34rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
  animation: detailFadeUp .42s ease .1s both;
}

.panel-title {
  color: #1F2933;
  font-size: 30rpx;
  font-weight: 850;
}

.detail-text {
  margin-top: 18rpx;
  color: #6B7280;
  font-size: 25rpx;
  line-height: 1.65;
  white-space: pre-line;
}

.detail-images {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.detail-long-image {
  width: 100%;
  min-height: 280rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #FFF9F3;
  display: block;
}

.more-detail-btn {
  width: 280rpx;
  height: 72rpx;
  margin: 10rpx auto 0;
  padding: 0;
  border-radius: 999rpx;
  background: #FFF3E8;
  color: #FF5A00;
  border: 1rpx solid rgba(255, 106, 0, .16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.more-detail-btn::after {
  border: 0;
}

.note-panel {
  margin-bottom: 8rpx;
}

.detail-contact-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255,106,0,.14);
  box-shadow: 0 18rpx 48rpx rgba(255,106,0,.10);
}

.contact-title {
  color: #1F2933;
  font-size: 28rpx;
  font-weight: 950;
}

.contact-subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.4;
}

.detail-contact-btn {
  flex: 0 0 180rpx;
  height: 68rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #ffffff;
  color: #FF5A00;
  border: 1rpx solid rgba(255,106,0,.24);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1;
  box-sizing: border-box;
}

.primary-btn {
  height: 96rpx;
  margin-top: 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF7A00 0%, #FF4D00 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 850;
  box-shadow: 0 18rpx 40rpx rgba(32, 32, 32, .18);
}

.loading {
  padding: 80rpx 28rpx;
  color: #6b7280;
}

/* Youth brand visual refresh */
.page {
  background:
    radial-gradient(circle at 90% 0%, rgba(255,210,26,.14), transparent 30%),
    linear-gradient(180deg, #FFF9F3 0%, #ffffff 48%, #ffffff 100%);
  animation: pageFade .34s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.detail-swiper {
  border-radius: 34rpx;
  box-shadow: 0 28rpx 68rpx rgba(255,106,0,.16);
}

.cover-keyring,
.cover-pet,
.cover-wood {
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .75), transparent 22%),
    linear-gradient(135deg, #FFF0DB, #FFD21A 52%, #FF5A00);
}

.detail-badge,
.badge-new,
.badge-hot {
  background: rgba(255, 255, 255, .92);
  color: #FF5A00;
  box-shadow: 0 10rpx 24rpx rgba(255,106,0,.10);
}

.badge-best {
  background: linear-gradient(135deg, #FF7A00, #FFD21A);
  color: #fff;
}

.eyebrow {
  color: #FFD21A;
}

.product-title,
.panel-title {
  color: #1F2933;
  font-weight: 950;
}

.product-intro,
.detail-text {
  color: #817679;
}

.category-line,
.benefit-item,
.recommend-tip {
  background: #FFF3E8;
  color: #FF5A00;
}

.price {
  color: #FF4D00;
  font-weight: 950;
}

.panel {
  border: 1rpx solid rgba(255,106,0,.14);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, .86);
  box-shadow: 0 18rpx 48rpx rgba(255,106,0,.10);
  backdrop-filter: blur(18rpx);
}

.detail-long-image {
  border-radius: 24rpx;
  background: #FFF3E8;
}

.primary-btn {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  box-shadow: 0 18rpx 40rpx rgba(255,106,0,.16);
  font-weight: 950;
}

.share-btn {
  border: 1rpx solid rgba(255,106,0,.16);
  background: #FFF3E8;
  color: #FF5A00;
}

/* Runtime theme variables */
.page {
  background: linear-gradient(180deg, var(--page-top-color, #FFF9F3) 0%, #ffffff 48%, var(--page-bottom-color, #ffffff) 100%);
}

.detail-swiper,
.panel {
  box-shadow: 0 18rpx 48rpx var(--theme-shadow, rgba(255,106,0,.10));
}

.panel {
  border-radius: var(--card-radius, 30rpx);
  background: var(--card-color, rgba(255,255,255,.86));
}

.primary-btn {
  border-radius: var(--button-radius, 999rpx);
  background: linear-gradient(135deg, var(--button-start, #FF7A00), var(--button-end, #FF4D00));
}

.eyebrow,
.category-line,
.benefit-item,
.recommend-tip,
.share-btn {
  color: var(--accent-color, #FF5A00);
}

.product-title,
.panel-title {
  color: var(--text-color, #1F2933);
}

.product-intro,
.detail-text {
  color: var(--muted-color, #817679);
}

.price {
  color: var(--price-color, #FF4D00);
}

.category-line,
.benefit-item,
.share-btn {
  background: var(--soft-color, #FFF3E8);
}
