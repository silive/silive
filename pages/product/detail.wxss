.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f4f9ff 0%, #ffffff 48%, #eef6ff 100%);
}

.detail-swiper {
  position: relative;
  height: 520rpx;
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 56rpx rgba(63, 45, 42, .16);
}

.detail-cover {
  width: 100%;
  height: 520rpx;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-video {
  width: 100%;
  height: 520rpx;
  display: block;
}

.cover-keyring {
  background: radial-gradient(circle at 58% 42%, #ffffff 0 15%, transparent 16%), linear-gradient(135deg, #8ec5ff, #1677ff);
}

.cover-pet {
  background: radial-gradient(circle at 48% 38%, #e6f7ff 0 18%, transparent 19%), linear-gradient(135deg, #e6f7ff, #1677ff);
}

.cover-wood {
  background: repeating-linear-gradient(35deg, rgba(255,255,255,.18) 0 10rpx, transparent 10rpx 22rpx), linear-gradient(135deg, #1677ff, #1677ff);
}

.detail-badge {
  position: absolute;
  left: 24rpx;
  top: 52rpx;
  z-index: 3;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .9);
  color: #1677ff;
  font-size: 22rpx;
  font-weight: 850;
  display: flex;
  align-items: center;
}

.badge-new {
  background: rgba(255, 255, 255, .92);
  color: #8d5a54;
}

.badge-hot {
  background: #eef6ff;
  color: #1677ff;
}

.badge-best {
  background: #1f2937;
  color: #f8fbff;
}

.detail-main {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 34rpx;
}

.eyebrow {
  color: #b96f67;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  font-weight: 800;
}

.product-title {
  margin-top: 10rpx;
  color: #1f2937;
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 850;
}

.product-intro {
  margin-top: 14rpx;
  color: #6b7280;
  font-size: 25rpx;
}

.category-line {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  margin-top: 18rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f4f9ff;
  color: #8d5a54;
  font-size: 21rpx;
  font-weight: 800;
}

.price {
  color: #1677ff;
  font-size: 42rpx;
  font-weight: 850;
  white-space: nowrap;
}

.price-box {
  flex: 0 0 auto;
  text-align: right;
}

.recommend-tip {
  width: 210rpx;
  margin-top: 10rpx;
  color: #8d5a54;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.35;
}

.benefit-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.benefit-item {
  min-height: 38rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f4f9ff;
  color: #8d5a54;
  display: flex;
  align-items: center;
  font-size: 21rpx;
  font-weight: 800;
}

.top-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 26rpx;
}

.normal-actions {
  display: grid;
  grid-template-columns: 150rpx minmax(0, 1fr) minmax(0, 1fr);
  gap: 14rpx;
  margin-top: 26rpx;
}

.primary-btn.compact,
.share-btn,
.cart-entry-btn {
  height: 82rpx;
  margin-top: 0;
}

.cart-entry-btn {
  position: relative;
  padding: 0;
  border-radius: 999rpx;
  border: 1rpx solid rgba(22,119,255,.18);
  background: #eef6ff;
  color: #1677ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1;
  box-sizing: border-box;
  overflow: visible;
}

.cart-entry-icon {
  font-size: 34rpx;
  line-height: 1;
}

.cart-entry-badge {
  position: absolute;
  top: -10rpx;
  right: -6rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff6b35;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 950;
  line-height: 34rpx;
  box-sizing: border-box;
}

.share-btn {
  border-radius: 999rpx;
  background: #f4f9ff;
  color: #8d5a54;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 850;
}

.cart-entry-btn::after,
.primary-btn::after,
.share-btn::after,
.detail-contact-btn::after {
  border: 0;
}

.panel {
  margin-top: 34rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.panel-title {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 850;
}

.detail-text {
  margin-top: 18rpx;
  color: #5f5753;
  font-size: 25rpx;
  line-height: 1.65;
  white-space: pre-line;
}

.detail-images {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.detail-long-image {
  width: 100%;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f4f9ff;
}

.note-panel {
  margin-bottom: 8rpx;
}

.detail-contact-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(22,119,255,.14);
  box-shadow: 0 18rpx 48rpx rgba(22,119,255,.10);
}

.contact-title {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 950;
}

.contact-subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.4;
}

.detail-contact-btn {
  flex: 0 0 180rpx;
  height: 68rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 950;
  line-height: 1;
  box-sizing: border-box;
}

.primary-btn {
  height: 96rpx;
  margin-top: 36rpx;
  border-radius: 999rpx;
  background: #1f2937;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 850;
  box-shadow: 0 18rpx 40rpx rgba(32, 32, 32, .18);
}

.loading {
  padding: 80rpx 28rpx;
  color: #6b7280;
}

/* Youth brand visual refresh */
.page {
  background:
    radial-gradient(circle at 90% 0%, rgba(54,207,201,.14), transparent 30%),
    linear-gradient(180deg, #f4f9ff 0%, #ffffff 48%, #ffffff 100%);
  animation: pageFade .34s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.detail-swiper {
  border-radius: 34rpx;
  box-shadow: 0 28rpx 68rpx rgba(22,119,255,.16);
}

.cover-keyring,
.cover-pet,
.cover-wood {
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .75), transparent 22%),
    linear-gradient(135deg, #dcecff, #36cfc9 52%, #1677ff);
}

.detail-badge,
.badge-new,
.badge-hot {
  background: rgba(255, 255, 255, .92);
  color: #1677ff;
  box-shadow: 0 10rpx 24rpx rgba(22,119,255,.10);
}

.badge-best {
  background: linear-gradient(135deg, #1f2937, #36cfc9);
  color: #fff;
}

.eyebrow {
  color: #36cfc9;
}

.product-title,
.panel-title {
  color: #1f2937;
  font-weight: 950;
}

.product-intro,
.detail-text {
  color: #817679;
}

.category-line,
.benefit-item,
.recommend-tip {
  background: #eef6ff;
  color: #1677ff;
}

.price {
  color: #ff6b35;
  font-weight: 950;
}

.panel {
  border: 1rpx solid rgba(22,119,255,.14);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, .86);
  box-shadow: 0 18rpx 48rpx rgba(22,119,255,.10);
  backdrop-filter: blur(18rpx);
}

.detail-long-image {
  border-radius: 24rpx;
  background: #eef6ff;
}

.primary-btn {
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  box-shadow: 0 18rpx 40rpx rgba(22,119,255,.16);
  font-weight: 950;
}

.share-btn {
  border: 1rpx solid rgba(22,119,255,.16);
  background: #eef6ff;
  color: #1677ff;
}

/* Runtime theme variables */
.page {
  background: linear-gradient(180deg, var(--page-top-color, #f4f9ff) 0%, #ffffff 48%, var(--page-bottom-color, #ffffff) 100%);
}

.detail-swiper,
.panel {
  box-shadow: 0 18rpx 48rpx var(--theme-shadow, rgba(22,119,255,.10));
}

.panel {
  border-radius: var(--card-radius, 30rpx);
  background: var(--card-color, rgba(255,255,255,.86));
}

.primary-btn {
  border-radius: var(--button-radius, 999rpx);
  background: linear-gradient(135deg, var(--button-start, #1677ff), var(--button-end, #36cfc9));
}

.eyebrow,
.category-line,
.benefit-item,
.recommend-tip,
.share-btn {
  color: var(--accent-color, #1677ff);
}

.product-title,
.panel-title {
  color: var(--text-color, #1f2937);
}

.product-intro,
.detail-text {
  color: var(--muted-color, #817679);
}

.price {
  color: var(--price-color, #ff6b35);
}

.category-line,
.benefit-item,
.share-btn {
  background: var(--soft-color, #eef6ff);
}
