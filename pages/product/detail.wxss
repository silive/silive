.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fdf7f4 0%, #fffdfb 48%, #f4f8f6 100%);
}

.detail-swiper {
  position: relative;
  height: 520rpx;
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 56rpx rgba(63, 45, 42, .16);
}

.detail-cover {
  width: 100%;
  height: 520rpx;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-video {
  width: 100%;
  height: 520rpx;
  display: block;
}

.cover-keyring {
  background: radial-gradient(circle at 58% 42%, #ffffff 0 15%, transparent 16%), linear-gradient(135deg, #f4b7ae, #272322);
}

.cover-pet {
  background: radial-gradient(circle at 48% 38%, #fff2e9 0 18%, transparent 19%), linear-gradient(135deg, #dcefe9, #36554f);
}

.cover-wood {
  background: repeating-linear-gradient(35deg, rgba(255,255,255,.18) 0 10rpx, transparent 10rpx 22rpx), linear-gradient(135deg, #c79a5f, #3b2b24);
}

.detail-badge {
  position: absolute;
  left: 24rpx;
  top: 52rpx;
  z-index: 3;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .9);
  color: #272322;
  font-size: 22rpx;
  font-weight: 850;
  display: flex;
  align-items: center;
}

.badge-new {
  background: rgba(255, 255, 255, .92);
  color: #8d5a54;
}

.badge-hot {
  background: #fff1ee;
  color: #d35f55;
}

.badge-best {
  background: #202020;
  color: #fff6ef;
}

.detail-main {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 34rpx;
}

.eyebrow {
  color: #b96f67;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  font-weight: 800;
}

.product-title {
  margin-top: 10rpx;
  color: #242120;
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 850;
}

.product-intro {
  margin-top: 14rpx;
  color: #8d8582;
  font-size: 25rpx;
}

.category-line {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  margin-top: 18rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f7efec;
  color: #8d5a54;
  font-size: 21rpx;
  font-weight: 800;
}

.price {
  color: #d35f55;
  font-size: 42rpx;
  font-weight: 850;
  white-space: nowrap;
}

.price-box {
  flex: 0 0 auto;
  text-align: right;
}

.recommend-tip {
  width: 210rpx;
  margin-top: 10rpx;
  color: #8d5a54;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.35;
}

.benefit-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.benefit-item {
  min-height: 38rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f7efec;
  color: #8d5a54;
  display: flex;
  align-items: center;
  font-size: 21rpx;
  font-weight: 800;
}

.top-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 26rpx;
}

.primary-btn.compact,
.share-btn {
  height: 82rpx;
  margin-top: 0;
}

.share-btn {
  border-radius: 999rpx;
  background: #f7efec;
  color: #8d5a54;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 850;
}

.panel {
  margin-top: 34rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.panel-title {
  color: #242120;
  font-size: 30rpx;
  font-weight: 850;
}

.detail-text {
  margin-top: 18rpx;
  color: #5f5753;
  font-size: 25rpx;
  line-height: 1.65;
  white-space: pre-line;
}

.detail-images {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.detail-long-image {
  width: 100%;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f7efec;
}

.note-panel {
  margin-bottom: 8rpx;
}

.primary-btn {
  height: 96rpx;
  margin-top: 36rpx;
  border-radius: 999rpx;
  background: #202020;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 850;
  box-shadow: 0 18rpx 40rpx rgba(32, 32, 32, .18);
}

.loading {
  padding: 80rpx 28rpx;
  color: #8d8582;
}

/* Youth brand visual refresh */
.page {
  background:
    radial-gradient(circle at 90% 0%, rgba(255, 175, 115, .20), transparent 30%),
    linear-gradient(180deg, #fff8f5 0%, #fffefd 48%, #fff2f5 100%);
  animation: pageFade .34s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.detail-swiper {
  border-radius: 34rpx;
  box-shadow: 0 28rpx 68rpx rgba(255, 128, 130, .18);
}

.cover-keyring,
.cover-pet,
.cover-wood {
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .75), transparent 22%),
    linear-gradient(135deg, #ffd9e3, #ff9a7a 52%, #343036);
}

.detail-badge,
.badge-new,
.badge-hot {
  background: rgba(255, 255, 255, .92);
  color: #ff6d7c;
  box-shadow: 0 10rpx 24rpx rgba(255, 127, 116, .16);
}

.badge-best {
  background: linear-gradient(135deg, #26222a, #ff806c);
  color: #fff;
}

.eyebrow {
  color: #ff7f74;
}

.product-title,
.panel-title {
  color: #222024;
  font-weight: 950;
}

.product-intro,
.detail-text {
  color: #817679;
}

.category-line,
.benefit-item,
.recommend-tip {
  background: #fff0f3;
  color: #ff6d7c;
}

.price {
  color: #ff6b6b;
  font-weight: 950;
}

.panel {
  border: 1rpx solid rgba(255, 169, 158, .22);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, .86);
  box-shadow: 0 18rpx 48rpx rgba(255, 132, 128, .10);
  backdrop-filter: blur(18rpx);
}

.detail-long-image {
  border-radius: 24rpx;
  background: #fff0f3;
}

.primary-btn {
  background: linear-gradient(135deg, #ff7aa2, #ff8d60);
  box-shadow: 0 18rpx 40rpx rgba(255, 127, 116, .24);
  font-weight: 950;
}

.share-btn {
  border: 1rpx solid rgba(255, 128, 130, .22);
  background: #fff5f7;
  color: #ff6d7c;
}

/* Runtime theme variables */
.page {
  background: linear-gradient(180deg, var(--page-top-color, #fff8f5) 0%, #fffefd 48%, var(--page-bottom-color, #fff2f5) 100%);
}

.detail-swiper,
.panel {
  box-shadow: 0 18rpx 48rpx var(--theme-shadow, rgba(255,132,128,.12));
}

.panel {
  border-radius: var(--card-radius, 30rpx);
  background: var(--card-color, rgba(255,255,255,.86));
}

.primary-btn {
  border-radius: var(--button-radius, 999rpx);
  background: linear-gradient(135deg, var(--button-start, #ff7aa2), var(--button-end, #ff8d60));
}

.eyebrow,
.category-line,
.benefit-item,
.recommend-tip,
.share-btn {
  color: var(--accent-color, #ff6d7c);
}

.product-title,
.panel-title {
  color: var(--text-color, #222024);
}

.product-intro,
.detail-text {
  color: var(--muted-color, #817679);
}

.price {
  color: var(--price-color, #ff6b6b);
}

.category-line,
.benefit-item,
.share-btn {
  background: var(--soft-color, #fff0f3);
}
