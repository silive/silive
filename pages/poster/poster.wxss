.page {
  min-height: 100vh;
  padding: 30rpx 28rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FFF9F3 0%, #ffffff 52%, #FFF3E8 100%);
}

.title {
  color: #1F2933;
  font-size: 42rpx;
  font-weight: 850;
  margin-bottom: 24rpx;
}

.poster {
  width: 100%;
  border-radius: 24rpx;
  box-shadow: 0 18rpx 44rpx rgba(83, 69, 64, .12);
}

.poster-card {
  position: relative;
}

.poster-loading {
  height: 640rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid #FFD9BF;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 750px;
  height: 1200px;
}

.poster-info {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid #FFD9BF;
  box-shadow: 0 18rpx 48rpx rgba(255,106,0,.10);
}

.poster-brand {
  color: #1F2933;
  font-size: 34rpx;
  font-weight: 950;
}

.poster-copy,
.poster-code {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.poster-code {
  color: #FF5A00;
  font-weight: 900;
}

.save-btn {
  height: 88rpx;
  margin-top: 26rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.empty {
  margin-top: 120rpx;
  text-align: center;
  color: #6b7280;
  font-size: 26rpx;
}

/* Youth brand visual refresh */
.page {
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 126, 159, .18), transparent 28%),
    linear-gradient(180deg, #FFF9F3 0%, #ffffff 50%, #ffffff 100%);
  animation: pageFade .34s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.title {
  color: #1F2933;
  font-weight: 950;
}

.poster {
  border-radius: 30rpx;
  box-shadow: 0 24rpx 56rpx rgba(255,106,0,.14);
}

/* Runtime theme variables */
.page {
  background: linear-gradient(180deg, var(--page-top-color, #FFF9F3) 0%, #ffffff 50%, var(--page-bottom-color, #ffffff) 100%);
}

.title {
  color: var(--text-color, #1F2933);
}

.poster {
  box-shadow: 0 24rpx 56rpx var(--theme-shadow, rgba(255,106,0,.12));
}
