.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f4f9ff 0%, #ffffff 52%, #eef6ff 100%);
}

.summary {
  display: grid;
  grid-template-columns: 168rpx minmax(0, 1fr);
  gap: 22rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.summary-cover {
  width: 168rpx;
  height: 168rpx;
  border-radius: 18rpx;
  overflow: hidden;
}

.summary-image {
  width: 100%;
  height: 100%;
}

.cover-keyring {
  background: radial-gradient(circle at 58% 42%, #ffffff 0 15%, transparent 16%), linear-gradient(135deg, #8ec5ff, #1677ff);
}

.cover-pet {
  background: radial-gradient(circle at 48% 38%, #e6f7ff 0 18%, transparent 19%), linear-gradient(135deg, #e6f7ff, #1677ff);
}

.cover-wood {
  background: repeating-linear-gradient(35deg, rgba(255,255,255,.18) 0 10rpx, transparent 10rpx 22rpx), linear-gradient(135deg, #1677ff, #1677ff);
}

.summary-info {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.product-name {
  color: #1f2937;
  font-size: 31rpx;
  line-height: 1.28;
  font-weight: 850;
}

.product-intro {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.price {
  margin-top: auto;
  color: #1677ff;
  font-size: 36rpx;
  font-weight: 850;
}

.form-panel {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.panel-title {
  margin-bottom: 22rpx;
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 850;
}

.upload-preview {
  display: grid;
  grid-template-columns: 126rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #dcebff;
}

.upload-preview-image {
  width: 126rpx;
  height: 126rpx;
  border-radius: 16rpx;
}

.upload-preview-title {
  color: #1f2937;
  font-size: 27rpx;
  font-weight: 850;
}

.upload-preview-subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.45;
}

.ai-preview-card {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #dcebff;
}

.ai-loading {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
}

.ai-shimmer {
  width: 112rpx;
  height: 112rpx;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #dcecff 0%, #fff 45%, #dcecff 100%);
  background-size: 220% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  filter: blur(.2rpx);
}

@keyframes shimmer {
  0% { background-position: 120% 0; }
  100% { background-position: -120% 0; }
}

.ai-title {
  color: #1f2937;
  font-size: 27rpx;
  font-weight: 900;
}

.ai-subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.45;
}

.ai-preview-image {
  width: 100%;
  height: 520rpx;
  margin-top: 16rpx;
  border-radius: 18rpx;
  background: #f4f9ff;
  opacity: 0;
  animation: revealPreview .8s ease forwards;
}

@keyframes revealPreview {
  0% { opacity: 0; filter: blur(10rpx); transform: translateY(8rpx); }
  100% { opacity: 1; filter: blur(0); transform: translateY(0); }
}

.ai-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.ai-btn {
  height: 66rpx;
  border-radius: 999rpx;
  background: #f4f9ff;
  color: #8d5a54;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1;
}

.ai-btn.dark {
  background: #1f2937;
  color: #ffffff;
}

label,
.field {
  display: block;
  margin-top: 22rpx;
  color: #5f5753;
  font-size: 24rpx;
  font-weight: 800;
}

.field-tip {
  margin-top: 10rpx;
  color: #9a918d;
  font-size: 22rpx;
}

.field-tip.error {
  color: #1677ff;
  font-weight: 800;
}

.normal-order-panel {
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #dcebff;
}

.normal-order-title {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 950;
}

.cart-summary-list {
  display: grid;
  gap: 14rpx;
  margin-top: 16rpx;
}

.cart-summary-item {
  display: grid;
  grid-template-columns: 84rpx minmax(0, 1fr) auto;
  gap: 14rpx;
  align-items: center;
}

.cart-summary-image {
  width: 84rpx;
  height: 84rpx;
  border-radius: 16rpx;
  background: #eef6ff;
}

.cart-summary-info {
  min-width: 0;
}

.cart-summary-name {
  color: #1f2937;
  font-size: 24rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-summary-meta,
.quantity-price {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 21rpx;
  font-weight: 700;
}

.cart-summary-subtotal {
  color: #ff6b35;
  font-size: 24rpx;
  font-weight: 950;
}

.quantity-row,
.normal-total {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.quantity-label {
  color: #1f2937;
  font-size: 24rpx;
  font-weight: 900;
}

.quantity-stepper {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  max-width: 48rpx;
  min-height: 48rpx;
  max-height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: #eef6ff;
  color: #1677ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 950;
  line-height: 48rpx;
  flex: 0 0 48rpx;
  box-sizing: border-box;
}

.quantity-num {
  width: 60rpx;
  min-width: 60rpx;
  color: #1f2937;
  text-align: center;
  font-size: 26rpx;
  font-weight: 950;
  line-height: 48rpx;
}

.quantity-btn::after {
  border: 0;
}

.normal-total {
  padding-top: 16rpx;
  border-top: 1rpx solid #eef6ff;
  color: #6b7280;
  font-size: 23rpx;
  font-weight: 800;
}

.normal-total-price {
  color: #ff6b35;
  font-size: 30rpx;
  font-weight: 950;
}

input,
textarea {
  width: 100%;
  margin-top: 12rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #dcebff;
  color: #1f2937;
  box-sizing: border-box;
  font-size: 26rpx;
}

input {
  height: 78rpx;
}

.inline-control {
  display: block;
}

.inline-control input {
  margin-top: 12rpx;
}

.mini-btn,
.light-btn {
  height: 70rpx;
  border-radius: 999rpx;
  background: #e6f7ff;
  color: #24302d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1;
}

.mini-btn {
  margin-top: 12rpx;
}

.address-action {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-start;
}

.light-btn {
  width: 248rpx;
  background: #f4f9ff;
  color: #8d5a54;
}

.delivery-section {
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 251, .82);
  border: 1rpx solid rgba(22,119,255,.16);
}

.delivery-tabs {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.delivery-tab {
  height: 72rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #817679;
  border: 1rpx solid rgba(22,119,255,.16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.delivery-tab.active {
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(22,119,255,.13);
}

.pickup-panel {
  margin-top: 18rpx;
}

.pickup-tip {
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.45;
}

.pickup-tip.warn {
  color: #ef4444;
  background: #eef6ff;
  font-weight: 800;
}

.pickup-store-list {
  display: grid;
  gap: 14rpx;
  margin-top: 14rpx;
}

.pickup-store {
  padding: 16rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid rgba(22,119,255,.16);
}

.pickup-store.selected {
  border-color: #36cfc9;
  box-shadow: 0 12rpx 30rpx rgba(22,119,255,.09);
}

.pickup-store-title {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 950;
}

.pickup-tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #1f2937;
  color: #fff;
  font-size: 18rpx;
  font-weight: 900;
}

.pickup-tag.soft {
  background: #eef6ff;
  color: #1677ff;
}

.pickup-line {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 21rpx;
  line-height: 1.45;
}

.pickup-distance {
  margin-top: 8rpx;
  color: #ff6b35;
  font-size: 22rpx;
  font-weight: 900;
}

.pickup-select {
  width: 100%;
  min-height: 72rpx;
  margin: 18rpx 0 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #9dccff;
  color: #1677ff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.pickup-store.selected .pickup-select {
  border: none;
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(22,119,255,.13);
}

.upload-field {
  padding: 18rpx;
  border-radius: 20rpx;
  border: 1rpx dashed #cfe3ff;
  background: #ffffff;
}

.upload-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.upload-label {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 900;
}

.upload-hint {
  margin-top: 8rpx;
  color: #9a918d;
  font-size: 21rpx;
  font-weight: 600;
}

.upload-add {
  width: 176rpx;
  height: 66rpx;
  border-radius: 999rpx;
  background: #1f2937;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1;
}

.upload-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.upload-tile {
  position: relative;
  aspect-ratio: 1 / 1;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f4f9ff;
  border: 1rpx solid #dcebff;
}

.upload-tile-image {
  width: 100%;
  height: 100%;
}

.upload-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: rgba(32, 32, 32, .76);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
}

.upload-more,
.upload-drop {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8d5a54;
  font-size: 42rpx;
  font-weight: 800;
}

.upload-drop {
  height: 176rpx;
  margin-top: 18rpx;
  flex-direction: column;
  border-radius: 18rpx;
  border: 1rpx dashed #cfe3ff;
  background: rgba(255, 255, 255, .62);
  color: #6b7280;
  font-size: 23rpx;
}

.upload-plus {
  margin-bottom: 8rpx;
  color: #1f2937;
  font-size: 48rpx;
  line-height: 1;
}

textarea {
  height: 150rpx;
  padding-top: 18rpx;
}

.pay-btn {
  height: 96rpx;
  margin-top: 34rpx;
  border-radius: 999rpx;
  background: #1f2937;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 850;
  box-shadow: 0 18rpx 40rpx rgba(32, 32, 32, .18);
}

/* Youth brand visual refresh */
.page {
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 126, 159, .18), transparent 28%),
    linear-gradient(180deg, #f4f9ff 0%, #ffffff 50%, #ffffff 100%);
  animation: pageFade .34s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.summary,
.form-panel,
.upload-preview,
.ai-preview-card {
  border: 1rpx solid rgba(22,119,255,.14);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .88);
  box-shadow: 0 18rpx 48rpx rgba(22,119,255,.10);
  backdrop-filter: blur(18rpx);
}

.summary-cover,
.upload-preview-image,
.ai-preview-image,
.upload-tile {
  border-radius: 24rpx;
}

.cover-keyring,
.cover-pet,
.cover-wood {
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .75), transparent 22%),
    linear-gradient(135deg, #dcecff, #36cfc9 52%, #1677ff);
}

.product-name,
.panel-title,
.upload-preview-title,
.upload-label,
.ai-title {
  color: #1f2937;
  font-weight: 950;
}

.product-intro,
.upload-preview-subtitle,
.upload-hint,
.ai-subtitle,
.field {
  color: #817679;
}

.price {
  color: #ff6b35;
  font-weight: 950;
}

input,
textarea {
  border-color: rgba(22,119,255,.16);
  border-radius: 22rpx;
  background: #ffffff;
}

.field-tip.error {
  color: #ef4444;
}

.light-btn,
.ai-btn,
.upload-drop {
  background: #eef6ff;
  color: #1677ff;
}

.ai-btn.dark,
.upload-add,
.pay-btn {
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  color: #fff;
  box-shadow: 0 18rpx 40rpx rgba(22,119,255,.16);
}

.upload-field {
  border-color: rgba(22,119,255,.20);
  background: rgba(255, 250, 251, .82);
}

.normal-tip {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #eef6ff;
  font-size: 24rpx;
  line-height: 1.55;
}

/* Runtime theme variables */
.page {
  background: linear-gradient(180deg, var(--page-top-color, #f4f9ff) 0%, #ffffff 50%, var(--page-bottom-color, #ffffff) 100%);
}

.summary,
.form-panel,
.upload-preview,
.ai-preview-card {
  border-radius: var(--card-radius, 28rpx);
  background: var(--card-color, rgba(255,255,255,.88));
  box-shadow: 0 18rpx 48rpx var(--theme-shadow, rgba(22,119,255,.10));
}

.ai-btn.dark,
.upload-add,
.pay-btn {
  border-radius: var(--button-radius, 999rpx);
  background: linear-gradient(135deg, var(--button-start, #1677ff), var(--button-end, #36cfc9));
}

.product-name,
.panel-title,
.upload-label,
.ai-title {
  color: var(--text-color, #1f2937);
}

.product-intro,
.upload-hint,
.ai-subtitle,
.field {
  color: var(--muted-color, #817679);
}

.price {
  color: var(--price-color, #ff6b35);
}

.light-btn,
.ai-btn,
.upload-drop,
.delivery-section,
.pickup-tip,
.pickup-store {
  background: var(--soft-color, #eef6ff);
  color: var(--accent-color, #1677ff);
}
