.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fdf7f4 0%, #fffdfb 52%, #f4f8f6 100%);
}

.summary {
  display: grid;
  grid-template-columns: 168rpx minmax(0, 1fr);
  gap: 22rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.summary-cover {
  width: 168rpx;
  height: 168rpx;
  border-radius: 18rpx;
  overflow: hidden;
}

.summary-image {
  width: 100%;
  height: 100%;
}

.cover-keyring {
  background: radial-gradient(circle at 58% 42%, #ffffff 0 15%, transparent 16%), linear-gradient(135deg, #f4b7ae, #272322);
}

.cover-pet {
  background: radial-gradient(circle at 48% 38%, #fff2e9 0 18%, transparent 19%), linear-gradient(135deg, #dcefe9, #36554f);
}

.cover-wood {
  background: repeating-linear-gradient(35deg, rgba(255,255,255,.18) 0 10rpx, transparent 10rpx 22rpx), linear-gradient(135deg, #c79a5f, #3b2b24);
}

.summary-info {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.product-name {
  color: #242120;
  font-size: 31rpx;
  line-height: 1.28;
  font-weight: 850;
}

.product-intro {
  margin-top: 10rpx;
  color: #8d8582;
  font-size: 23rpx;
}

.price {
  margin-top: auto;
  color: #d35f55;
  font-size: 36rpx;
  font-weight: 850;
}

.form-panel {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.panel-title {
  margin-bottom: 22rpx;
  color: #242120;
  font-size: 32rpx;
  font-weight: 850;
}

.upload-preview {
  display: grid;
  grid-template-columns: 126rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #fffaf7;
  border: 1rpx solid #eadcd7;
}

.upload-preview-image {
  width: 126rpx;
  height: 126rpx;
  border-radius: 16rpx;
}

.upload-preview-title {
  color: #242120;
  font-size: 27rpx;
  font-weight: 850;
}

.upload-preview-subtitle {
  margin-top: 8rpx;
  color: #8d8582;
  font-size: 22rpx;
  line-height: 1.45;
}

.ai-preview-card {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fffaf7;
  border: 1rpx solid #eadcd7;
}

.ai-loading {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
}

.ai-shimmer {
  width: 112rpx;
  height: 112rpx;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #f1e5df 0%, #fff 45%, #f1e5df 100%);
  background-size: 220% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  filter: blur(.2rpx);
}

@keyframes shimmer {
  0% { background-position: 120% 0; }
  100% { background-position: -120% 0; }
}

.ai-title {
  color: #242120;
  font-size: 27rpx;
  font-weight: 900;
}

.ai-subtitle {
  margin-top: 8rpx;
  color: #8d8582;
  font-size: 22rpx;
  line-height: 1.45;
}

.ai-preview-image {
  width: 100%;
  height: 520rpx;
  margin-top: 16rpx;
  border-radius: 18rpx;
  background: #f7efec;
  opacity: 0;
  animation: revealPreview .8s ease forwards;
}

@keyframes revealPreview {
  0% { opacity: 0; filter: blur(10rpx); transform: translateY(8rpx); }
  100% { opacity: 1; filter: blur(0); transform: translateY(0); }
}

.ai-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.ai-btn {
  height: 66rpx;
  border-radius: 999rpx;
  background: #f7efec;
  color: #8d5a54;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1;
}

.ai-btn.dark {
  background: #202020;
  color: #ffffff;
}

label,
.field {
  display: block;
  margin-top: 22rpx;
  color: #5f5753;
  font-size: 24rpx;
  font-weight: 800;
}

.field-tip {
  margin-top: 10rpx;
  color: #9a918d;
  font-size: 22rpx;
}

.field-tip.error {
  color: #d35f55;
  font-weight: 800;
}

input,
textarea {
  width: 100%;
  margin-top: 12rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #fbfbfd;
  border: 1rpx solid #eadcd7;
  color: #242120;
  box-sizing: border-box;
  font-size: 26rpx;
}

input {
  height: 78rpx;
}

.inline-control {
  display: block;
}

.inline-control input {
  margin-top: 12rpx;
}

.mini-btn,
.light-btn {
  height: 70rpx;
  border-radius: 999rpx;
  background: #e4f0ec;
  color: #24302d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1;
}

.mini-btn {
  margin-top: 12rpx;
}

.address-action {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-start;
}

.light-btn {
  width: 248rpx;
  background: #f7efec;
  color: #8d5a54;
}

.upload-field {
  padding: 18rpx;
  border-radius: 20rpx;
  border: 1rpx dashed #d8c8c1;
  background: #fffaf7;
}

.upload-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.upload-label {
  color: #242120;
  font-size: 26rpx;
  font-weight: 900;
}

.upload-hint {
  margin-top: 8rpx;
  color: #9a918d;
  font-size: 21rpx;
  font-weight: 600;
}

.upload-add {
  width: 176rpx;
  height: 66rpx;
  border-radius: 999rpx;
  background: #202020;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 1;
}

.upload-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.upload-tile {
  position: relative;
  aspect-ratio: 1 / 1;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f7efec;
  border: 1rpx solid #eadcd7;
}

.upload-tile-image {
  width: 100%;
  height: 100%;
}

.upload-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: rgba(32, 32, 32, .76);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
}

.upload-more,
.upload-drop {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8d5a54;
  font-size: 42rpx;
  font-weight: 800;
}

.upload-drop {
  height: 176rpx;
  margin-top: 18rpx;
  flex-direction: column;
  border-radius: 18rpx;
  border: 1rpx dashed #d8c8c1;
  background: rgba(255, 255, 255, .62);
  color: #8d8582;
  font-size: 23rpx;
}

.upload-plus {
  margin-bottom: 8rpx;
  color: #242120;
  font-size: 48rpx;
  line-height: 1;
}

textarea {
  height: 150rpx;
  padding-top: 18rpx;
}

.pay-btn {
  height: 96rpx;
  margin-top: 34rpx;
  border-radius: 999rpx;
  background: #202020;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 850;
  box-shadow: 0 18rpx 40rpx rgba(32, 32, 32, .18);
}

/* Youth brand visual refresh */
.page {
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 126, 159, .18), transparent 28%),
    linear-gradient(180deg, #fff8f5 0%, #fffefd 50%, #fff2f5 100%);
  animation: pageFade .34s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.summary,
.form-panel,
.upload-preview,
.ai-preview-card {
  border: 1rpx solid rgba(255, 169, 158, .22);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .88);
  box-shadow: 0 18rpx 48rpx rgba(255, 132, 128, .10);
  backdrop-filter: blur(18rpx);
}

.summary-cover,
.upload-preview-image,
.ai-preview-image,
.upload-tile {
  border-radius: 24rpx;
}

.cover-keyring,
.cover-pet,
.cover-wood {
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .75), transparent 22%),
    linear-gradient(135deg, #ffd9e3, #ff9a7a 52%, #343036);
}

.product-name,
.panel-title,
.upload-preview-title,
.upload-label,
.ai-title {
  color: #222024;
  font-weight: 950;
}

.product-intro,
.upload-preview-subtitle,
.upload-hint,
.ai-subtitle,
.field {
  color: #817679;
}

.price {
  color: #ff6b6b;
  font-weight: 950;
}

input,
textarea {
  border-color: rgba(255, 128, 130, .18);
  border-radius: 22rpx;
  background: #fffafb;
}

.field-tip.error {
  color: #ff5f6d;
}

.light-btn,
.ai-btn,
.upload-drop {
  background: #fff0f3;
  color: #ff6d7c;
}

.ai-btn.dark,
.upload-add,
.pay-btn {
  background: linear-gradient(135deg, #ff7aa2, #ff8d60);
  color: #fff;
  box-shadow: 0 18rpx 40rpx rgba(255, 127, 116, .24);
}

.upload-field {
  border-color: rgba(255, 128, 130, .28);
  background: rgba(255, 250, 251, .82);
}

/* Runtime theme variables */
.page {
  background: linear-gradient(180deg, var(--page-top-color, #fff8f5) 0%, #fffefd 50%, var(--page-bottom-color, #fff2f5) 100%);
}

.summary,
.form-panel,
.upload-preview,
.ai-preview-card {
  border-radius: var(--card-radius, 28rpx);
  background: var(--card-color, rgba(255,255,255,.88));
  box-shadow: 0 18rpx 48rpx var(--theme-shadow, rgba(255,132,128,.10));
}

.ai-btn.dark,
.upload-add,
.pay-btn {
  border-radius: var(--button-radius, 999rpx);
  background: linear-gradient(135deg, var(--button-start, #ff7aa2), var(--button-end, #ff8d60));
}

.product-name,
.panel-title,
.upload-label,
.ai-title {
  color: var(--text-color, #222024);
}

.product-intro,
.upload-hint,
.ai-subtitle,
.field {
  color: var(--muted-color, #817679);
}

.price {
  color: var(--price-color, #ff6b6b);
}

.light-btn,
.ai-btn,
.upload-drop {
  background: var(--soft-color, #fff0f3);
  color: var(--accent-color, #ff6d7c);
}
