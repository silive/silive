<view class="page">
  <view class="page-head">
    <view class="title">选择自提点</view>
    <view class="subtitle">按距离从近到远展示，选择后自动返回确认订单</view>
  </view>

  <view wx:if="{{stores.length}}" class="store-list">
    <view class="store-card {{selectedId === item.id ? 'selected' : ''}}" wx:for="{{stores}}" wx:key="id" bindtap="selectStore" data-id="{{item.id}}">
      <view class="store-main">
        <view class="store-title">
          <text>{{item.name}}</text>
          <text wx:if="{{item.nearest}}" class="tag">最近</text>
          <text class="tag soft">支持自提</text>
        </view>
        <view class="line">{{item.address}}</view>
        <view class="line">电话：{{item.phone || '到店咨询'}} · {{item.businessHours || '营业时间请咨询门店'}}</view>
        <view wx:if="{{item.distanceText}}" class="distance">距离 {{item.distanceText}}</view>
      </view>
      <view class="select-state">{{selectedId === item.id ? '已选择' : '选择'}}</view>
    </view>
  </view>

  <view wx:else class="empty">暂无可用自提点</view>
</view>
