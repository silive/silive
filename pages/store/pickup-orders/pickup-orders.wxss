@import "../store.wxss";

.batch-bar {
  margin-top: 18rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.batch-text {
  flex: 1;
  min-width: 0;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.4;
}

.batch-link {
  height: 58rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #FFF3E8;
  color: #FF5A00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  box-sizing: border-box;
  white-space: nowrap;
}

.store-order-row.batching {
  grid-template-columns: auto 112rpx minmax(0, 1fr);
  align-items: center;
}

.select-dot {
  width: 42rpx;
  height: 42rpx;
  min-width: 42rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 106, 0, .35);
  background: #fff;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 950;
  line-height: 1;
  box-sizing: border-box;
}

.select-dot.selected {
  border-color: transparent;
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
}

.select-dot.disabled {
  border-color: rgba(107, 114, 128, .2);
  background: #f3f4f6;
}

.pickup-actions {
  margin-top: 14rpx;
}

.primary-btn.mini {
  width: 100%;
  height: 68rpx;
  margin-top: 0;
  font-size: 23rpx;
}

.disabled-reason {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #9ca3af;
  font-size: 21rpx;
  font-weight: 850;
}

.batch-footer {
  position: sticky;
  bottom: 24rpx;
  margin-top: 24rpx;
  padding: 16rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 18rpx 48rpx rgba(255,106,0,.14);
  box-sizing: border-box;
}

.batch-submit {
  width: 100%;
  margin-top: 0;
}

button::after {
  border: 0;
}
