@import "../store.wxss";

.code-card {
  margin-top: 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 18rpx 48rpx rgba(22,119,255,.10);
  border: 1rpx solid rgba(22,119,255,.14);
}

.store-code {
  display: block;
  width: 420rpx;
  height: 420rpx;
  margin: 20rpx auto;
  border-radius: 28rpx;
  background: #f4f9ff;
}

.code-tip {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #eef6ff;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
}

.center {
  text-align: center;
  padding: 80rpx 0;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.secondary-btn {
  height: 84rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #eef6ff;
  color: #1677ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 950;
  line-height: 1;
  box-sizing: border-box;
}

.compact {
  margin-top: 0;
}

button::after {
  border: 0;
}
