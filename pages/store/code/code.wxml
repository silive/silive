<view class="store-page {{themeClass}}" style="{{themeStyle}}">
  <view wx:if="{{storeInfo}}" class="store-card" style="{{cardStyle}}">
    <view class="eyebrow">STORE QR CODE</view>
    <view class="store-name">我的推广码</view>
    <view class="store-meta">{{storeInfo.name}} · {{storeInfo.levelText || '合作门店'}}</view>
    <view class="store-address">顾客扫码进入后，30天内下单优先归属该门店推荐。</view>
  </view>

  <view class="code-card" style="{{cardStyle}}">
    <view wx:if="{{loading}}" class="muted center">正在生成门店小程序码...</view>
    <image wx:elif="{{qrcodeUrl}}" class="store-code" src="{{qrcodeUrl}}" mode="aspectFit" show-menu-by-longpress="true" />
    <view wx:else class="muted center">推广码暂时不可用</view>
    <view class="code-tip">顾客扫码或打开分享卡片即可进入门店推荐页面。</view>
    <view class="action-row">
      <button class="primary-btn compact" open-type="share">分享给好友</button>
      <button class="secondary-btn compact" bindtap="saveCode">保存门店码</button>
      <button class="secondary-btn compact" bindtap="createStorePoster">生成门店海报</button>
    </view>
  </view>
</view>
