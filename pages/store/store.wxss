.store-page {
  min-height: 100vh;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff8f5 0%, #fffefd 50%, #fff2f5 100%);
}

.store-card,
.stat-card,
.entry-card,
.order-card,
.profile-card,
.verify-card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .88);
  box-shadow: 0 18rpx 48rpx rgba(255, 132, 128, .10);
  border: 1rpx solid rgba(255, 169, 158, .22);
}

.store-card,
.profile-card,
.verify-card {
  padding: 28rpx;
}

.eyebrow {
  color: #ff7a00;
  font-size: 20rpx;
  font-weight: 950;
}

.store-name {
  margin-top: 8rpx;
  color: #222024;
  font-size: 40rpx;
  font-weight: 950;
}

.store-meta,
.store-address,
.entry-sub,
.stat-label,
.info-line,
.order-sub,
.muted {
  color: #8d7e80;
  font-size: 22rpx;
  line-height: 1.5;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-card {
  padding: 22rpx;
}

.stat-value {
  color: #ff5a3c;
  font-size: 38rpx;
  font-weight: 950;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.entry-card {
  padding: 24rpx 16rpx;
  min-height: 176rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.entry-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff7aa2, #ff8d60);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 950;
}

.entry-title,
.section-title {
  margin-top: 12rpx;
  color: #222024;
  font-size: 27rpx;
  font-weight: 950;
}

.profile-card,
.list {
  margin-top: 24rpx;
}

.order-card {
  padding: 22rpx;
  margin-top: 16rpx;
}

.order-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.order-title {
  color: #222024;
  font-size: 27rpx;
  font-weight: 950;
}

.pill {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fff0f3;
  color: #ff5a3c;
  font-size: 20rpx;
  font-weight: 900;
}

.amount {
  margin-top: 10rpx;
  color: #ff5a3c;
  font-size: 30rpx;
  font-weight: 950;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.tab {
  height: 60rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #8d7e80;
  font-size: 22rpx;
  font-weight: 900;
}

.tab.active {
  background: linear-gradient(135deg, #ff7aa2, #ff8d60);
  color: #fff;
}

.input {
  width: 100%;
  height: 84rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #fffafb;
  border: 1rpx solid rgba(255, 128, 130, .18);
  box-sizing: border-box;
}

.primary-btn {
  height: 88rpx;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7aa2, #ff8d60);
  color: #fff;
  font-size: 28rpx;
  font-weight: 950;
}
