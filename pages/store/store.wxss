.store-page {
  min-height: 100vh;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FFF9F3 0%, #ffffff 50%, #ffffff 100%);
}

.store-card,
.stat-card,
.entry-card,
.order-card,
.profile-card,
.verify-card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .88);
  box-shadow: 0 18rpx 48rpx rgba(255,106,0,.10);
  border: 1rpx solid rgba(255,106,0,.14);
}

.store-card,
.profile-card,
.verify-card {
  padding: 28rpx;
}

.eyebrow {
  color: #FF5A00;
  font-size: 20rpx;
  font-weight: 950;
}

.store-name {
  margin-top: 8rpx;
  color: #1F2933;
  font-size: 40rpx;
  font-weight: 950;
}

.store-meta,
.store-address,
.entry-sub,
.stat-label,
.info-line,
.order-sub,
.muted {
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.5;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-card {
  padding: 22rpx;
}

.stat-value {
  color: #FF4D00;
  font-size: 38rpx;
  font-weight: 950;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 24rpx;
  box-sizing: border-box;
}

.entry-card {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  margin: 0;
  padding: 24rpx 14rpx;
  min-height: 176rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.3;
  box-sizing: border-box;
  overflow: hidden;
}

.entry-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 950;
}

.entry-title,
.section-title {
  margin-top: 12rpx;
  color: #1F2933;
  font-size: 27rpx;
  font-weight: 950;
}

.entry-title,
.entry-sub {
  max-width: 100%;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.profile-card,
.list {
  margin-top: 24rpx;
}

.order-card {
  padding: 22rpx;
  margin-top: 16rpx;
}

.store-order-row {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: flex-start;
}

.store-order-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #FFF3E8;
  flex-shrink: 0;
}

.store-order-image {
  width: 100%;
  height: 100%;
  display: block;
  background: #FFF3E8;
}

.store-order-placeholder {
  width: 100%;
  height: 100%;
  color: #FF5A00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 950;
  text-align: center;
}

.store-order-info {
  min-width: 0;
}

.order-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.order-title {
  color: #1F2933;
  font-size: 27rpx;
  font-weight: 950;
}

.pill {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #FFF3E8;
  color: #FF4D00;
  font-size: 20rpx;
  font-weight: 900;
}

.amount {
  margin-top: 10rpx;
  color: #FF4D00;
  font-size: 30rpx;
  font-weight: 950;
}

.tabs {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.tab {
  height: 60rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #6b7280;
  font-size: 22rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-sizing: border-box;
}

.tab.active {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #fff;
}

.input {
  width: 100%;
  height: 84rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid rgba(255,106,0,.16);
  box-sizing: border-box;
}

.primary-btn {
  height: 88rpx;
  margin-top: 20rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 950;
  line-height: 1;
  box-sizing: border-box;
}

button::after {
  border: 0;
}
