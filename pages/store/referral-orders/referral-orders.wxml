<view class="store-page {{themeClass}}" style="{{themeStyle}}">
  <view class="store-card" style="{{cardStyle}}">
    <view class="eyebrow">REFERRAL ORDERS</view>
    <view class="store-name">我推广的订单</view>
    <view class="store-meta">只显示当前门店带来的订单</view>
  </view>
  <view class="stats-grid">
    <view class="stat-card" style="{{cardStyle}}"><view class="stat-value">{{summary.todayOrders || 0}}</view><view class="stat-label">今日订单</view></view>
    <view class="stat-card" style="{{cardStyle}}"><view class="stat-value">{{summary.monthOrders || 0}}</view><view class="stat-label">本月订单</view></view>
    <view class="stat-card" style="{{cardStyle}}"><view class="stat-value">¥{{summary.estimatedTotal || '0.00'}}</view><view class="stat-label">预计佣金</view></view>
    <view class="stat-card" style="{{cardStyle}}"><view class="stat-value">¥{{summary.payableTotal || '0.00'}}</view><view class="stat-label">当前可结算</view></view>
    <view class="stat-card" style="{{cardStyle}}"><view class="stat-value">¥{{summary.chargebackTotal || '0.00'}}</view><view class="stat-label">当前退款扣回</view></view>
    <view class="stat-card" style="{{cardStyle}}"><view class="stat-value">¥{{summary.actualPayable || '0.00'}}</view><view class="stat-label">本次预计到账</view></view>
    <view class="stat-card" style="{{cardStyle}}"><view class="stat-value">¥{{summary.settledTotal || '0.00'}}</view><view class="stat-label">累计已结算</view></view>
  </view>
  <view class="list">
    <view class="order-card" style="{{cardStyle}}" wx:for="{{orders}}" wx:key="id">
      <view class="store-order-row">
        <view class="store-order-cover">
          <image wx:if="{{item.productImage}}" class="store-order-image" src="{{item.productImage}}" mode="aspectFill" lazy-load />
          <view wx:else class="store-order-placeholder">非常智造</view>
        </view>
        <view class="store-order-info">
          <view class="order-head"><view><view class="order-title">{{item.productName}}</view><view class="order-sub">{{item.id}} · {{item.createdAtText || item.createdAt}}</view></view><view class="pill">{{item.storeSettlementStatusText || (item.storeSettlementStatus === 'settled' ? '已结算' : '待确认')}}</view></view>
          <view class="order-sub">客户：{{item.phone}} · {{item.status}} / {{item.paymentStatus}}</view>
          <view class="order-sub">来源：{{item.storeOrderTypeText || '外部顾客'}}<text wx:if="{{item.isStoreMemberOrder}}"> · 操作人：{{item.storeOperatorRoleText}} {{item.storeOperatorPhoneTail || '未知'}}</text></view>
          <view class="amount">订单 ¥{{item.amount}} · 佣金 ¥{{item.referralCommission}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
