@import "../store.wxss";

.verify-page {
  padding-bottom: 56rpx;
}

.scan-btn {
  width: 100%;
  margin-top: 28rpx;
  height: 88rpx;
  min-height: 88rpx;
  max-height: 88rpx;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}

.scan-btn::after {
  border: 0;
}

.manual-box {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f4f9ff;
  border: 1rpx solid rgba(22, 119, 255, .12);
}

.manual-title {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 900;
}

.code-input {
  width: 100%;
  height: 96rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(22, 119, 255, .18);
  color: #1f2937;
  font-size: 42rpx;
  font-weight: 950;
  letter-spacing: 8rpx;
  text-align: center;
  box-sizing: border-box;
}

.code-placeholder {
  color: #9ca3af;
  font-size: 28rpx;
  letter-spacing: 0;
}

.secondary-btn.verify-submit {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  max-height: 88rpx;
  margin-top: 18rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #1677ff;
  background: #ffffff;
  border: 1rpx solid rgba(22, 119, 255, .22);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}

.secondary-btn.verify-submit::after {
  border: 0;
}

.result-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.result-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #22c55e, #36cfc9);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 950;
}

.result-card.already .result-icon {
  background: linear-gradient(135deg, #f59e0b, #ff6b35);
}

.result-title {
  margin-top: 18rpx;
  color: #1f2937;
  font-size: 36rpx;
  font-weight: 950;
}

.result-row {
  margin-top: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  color: #1f2937;
  font-size: 26rpx;
  line-height: 1.5;
}

.result-row text:first-child {
  color: #6b7280;
  flex: 0 0 120rpx;
}

.result-row text:last-child {
  flex: 1;
  text-align: right;
  font-weight: 800;
}
