.cart-page {
  min-height: 100vh;
  padding: 30rpx 28rpx 150rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FFF9F3 0%, #ffffff 54%, #FFF3E8 100%);
}

.page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eyebrow {
  color: #FFD21A;
  font-size: 20rpx;
  font-weight: 900;
}

.title {
  margin-top: 8rpx;
  color: #1F2933;
  font-size: 42rpx;
  font-weight: 950;
}

.count {
  min-width: 86rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #FF5A00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  box-shadow: 0 12rpx 30rpx rgba(255,106,0,.10);
}

.cart-list {
  margin-top: 28rpx;
}

.cart-card {
  display: grid;
  grid-template-columns: 40rpx 120rpx minmax(0, 1fr);
  align-items: start;
  column-gap: 18rpx;
  row-gap: 14rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(255,106,0,.10);
  box-sizing: border-box;
}

.check {
  width: 36rpx;
  height: 36rpx;
  min-width: 36rpx;
  max-width: 36rpx;
  min-height: 36rpx;
  max-height: 36rpx;
  margin: 42rpx 0 0 !important;
  padding: 0 !important;
  border-radius: 50%;
  background: #FFF3E8;
  border: 2rpx solid #FFD9BF;
  color: #FF5A00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 36rpx !important;
  flex: 0 0 36rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.qty {
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  max-width: 56rpx;
  min-height: 56rpx;
  max-height: 56rpx;
  margin: 0 !important;
  padding: 0 !important;
  border-radius: 50%;
  background: #FFF3E8;
  color: #FF5A00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 56rpx !important;
  flex: 0 0 56rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.check::after,
.qty::after,
.remove::after,
.checkout::after,
.empty-btn::after {
  border: 0;
}

.check.checked {
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  border-color: transparent;
  color: #ffffff;
}

.cover {
  width: 120rpx;
  height: 120rpx;
  min-width: 120rpx;
  max-width: 120rpx;
  min-height: 120rpx;
  max-height: 120rpx;
  border-radius: 20rpx;
  background: #FFF3E8;
  display: block;
  overflow: hidden;
  box-sizing: border-box;
}

.placeholder {
  color: #FF5A00;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.info {
  flex: 1;
  min-width: 0;
}

.name {
  color: #1F2933;
  font-size: 28rpx;
  font-weight: 900;
}

.price,
.total {
  margin-top: 8rpx;
  color: #FF4D00;
  font-size: 28rpx;
  font-weight: 950;
}

.qty-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
  flex-wrap: nowrap;
}

.qty-num {
  width: 56rpx;
  min-width: 56rpx;
  color: #1F2933;
  text-align: center;
  font-weight: 900;
  line-height: 56rpx;
}

.remove {
  height: 46rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #FFF9F3;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}

.card-foot {
  grid-column: 2 / 4;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #FFF3E8;
}

.subtotal {
  color: #FF4D00;
  font-size: 24rpx;
  font-weight: 950;
}

.empty {
  margin-top: 110rpx;
  padding: 58rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(255,106,0,.10);
  text-align: center;
}

.empty-title {
  color: #1F2933;
  font-size: 32rpx;
  font-weight: 950;
}

.empty-desc {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.5;
}

.empty-btn {
  width: 190rpx;
  height: 68rpx;
  margin: 28rpx auto 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 950;
}

.bottom-bar {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 34rpx;
  min-height: 108rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(255,106,0,.16);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.total-label {
  color: #6b7280;
  font-size: 22rpx;
}

.checkout {
  min-width: 220rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF7A00, #FF4D00);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 950;
}
