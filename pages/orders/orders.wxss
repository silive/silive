.orders-page {
  min-height: 100vh;
  padding: 36rpx 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f4f9ff 0%, #ffffff 52%, #eef6ff 100%);
}

.page-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.eyebrow {
  color: #b96f67;
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.page-title {
  margin-top: 8rpx;
  color: #1f2937;
  font-size: 42rpx;
  font-weight: 900;
}

.order-count {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .9);
  color: #6b7280;
  font-size: 22rpx;
  font-weight: 850;
}

.login-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.login-card > view {
  min-width: 0;
}

.login-title {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 900;
}

.login-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.45;
}

.login-btn {
  width: auto;
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #1f2937;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  flex-shrink: 0;
  box-sizing: border-box;
  white-space: nowrap;
  transition: transform .16s ease, opacity .16s ease;
}

.login-btn:active {
  opacity: .86;
  transform: scale(.98);
}

.status-panel {
  margin-top: 32rpx;
  padding: 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.status-row {
  display: flex;
  justify-content: center;
  gap: 18rpx;
}

.status-row + .status-row {
  margin-top: 18rpx;
}

.top-row .status-entry {
  width: 30%;
}

.bottom-row .status-entry {
  width: 45%;
}

.status-entry {
  position: relative;
  height: 138rpx;
  padding: 22rpx 10rpx 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  color: #1f2937;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #dcebff;
  box-sizing: border-box;
  flex-shrink: 0;
}

.status-entry.active {
  background: #e6f4ff;
  color: #1f2937;
  border-color: #cfe3ff;
  box-shadow: 0 12rpx 28rpx rgba(36, 33, 32, .12);
}

.status-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #eef6ff;
  color: #5f5753;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.status-entry.active .status-icon {
  background: #1f2937;
  color: #ffffff;
}

.status-name {
  margin-top: 14rpx;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.status-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  min-width: 38rpx;
  height: 38rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #1f2937;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 19rpx;
  font-weight: 900;
}

.status-entry.active .status-badge {
  background: #1f2937;
  color: #ffffff;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 30rpx;
}

.section-title {
  color: #1f2937;
  font-size: 31rpx;
  font-weight: 900;
}

.section-subtitle {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.order-list {
  display: grid;
  gap: 18rpx;
  margin-top: 18rpx;
}

.order-card {
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .94);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.order-main {
  display: grid;
  grid-template-columns: 136rpx minmax(0, 1fr);
  gap: 18rpx;
}

.order-cover {
  width: 136rpx;
  height: 136rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #8ec5ff, #1677ff);
}

.order-image {
  width: 100%;
  height: 100%;
}

.order-placeholder {
  width: 100%;
  height: 100%;
  color: rgba(255, 255, 255, .82);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 900;
}

.order-info {
  min-width: 0;
}

.pickup-info {
  margin-top: 10rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  background: #eef6ff;
  border: 1rpx solid rgba(22,119,255,.14);
}

.pickup-code {
  color: #1f2937;
  font-size: 23rpx;
  font-weight: 900;
}

.order-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.product-name {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.28;
}

.status {
  flex-shrink: 0;
  color: #8d5a54;
  font-size: 21rpx;
  font-weight: 900;
}

.muted {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.4;
}

.amount {
  margin-top: 10rpx;
  color: #1677ff;
  font-size: 32rpx;
  font-weight: 900;
}

.actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.dark-btn,
.light-btn,
.upload-btn,
.cancel-btn,
.submit-btn {
  height: 66rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 850;
}

.dark-btn,
.submit-btn {
  background: #1f2937;
  color: #ffffff;
}

.light-btn,
.upload-btn {
  background: #f4f9ff;
  color: #8d5a54;
}

.empty-box {
  margin-top: 18rpx;
  padding: 44rpx 28rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
  text-align: center;
}

.empty-text {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-subtext {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 23rpx;
}

.recommend-head {
  margin-top: 36rpx;
}

.recommend-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 18rpx;
  padding-bottom: 24rpx;
}

.recommend-card {
  min-width: 0;
  padding: 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, .94);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.recommend-cover {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 18rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #e6f7ff, #1677ff);
}

.recommend-image {
  width: 100%;
  height: 100%;
}

.recommend-badge {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(31,41,55,.72);
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 900;
}

.recommend-name {
  margin-top: 14rpx;
  color: #1f2937;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.3;
}

.recommend-meta {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 20rpx;
}

.recommend-price {
  margin-top: 8rpx;
  color: #1677ff;
  font-size: 28rpx;
  font-weight: 900;
}

.refund-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  padding: 80rpx 28rpx;
  box-sizing: border-box;
  background: rgba(32, 32, 32, .28);
}

.refund-panel {
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 70rpx rgba(32, 32, 32, .18);
}

.refund-title {
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 900;
}

.field {
  margin-top: 20rpx;
  color: #5f5753;
  font-size: 24rpx;
  font-weight: 800;
}

input,
textarea {
  width: 100%;
  margin-top: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dcebff;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2937;
  box-sizing: border-box;
  font-size: 26rpx;
}

input {
  height: 76rpx;
}

textarea {
  height: 130rpx;
  padding-top: 18rpx;
}

.upload-btn {
  width: 100%;
  margin-top: 20rpx;
}

.refund-image {
  width: 168rpx;
  height: 168rpx;
  margin-top: 16rpx;
  border-radius: 18rpx;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.cancel-btn {
  background: #f1f1f3;
  color: #5f5753;
}

/* Youth brand visual refresh */
.orders-page {
  background:
    radial-gradient(circle at 10% 0%, rgba(255, 126, 159, .18), transparent 28%),
    linear-gradient(180deg, #f4f9ff 0%, #ffffff 50%, #ffffff 100%);
  animation: pageFade .34s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.eyebrow {
  color: #36cfc9;
}

.page-title,
.login-title,
.section-title,
.product-name,
.empty-text,
.recommend-name,
.refund-title {
  color: #1f2937;
  font-weight: 950;
}

.login-desc,
.section-subtitle,
.muted,
.empty-subtext,
.recommend-meta {
  color: #6b7280;
}

.order-count,
.login-card,
.status-panel,
.order-card,
.empty-box,
.recommend-card,
.refund-panel {
  border: 1rpx solid rgba(22,119,255,.14);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .86);
  box-shadow: 0 18rpx 48rpx rgba(22,119,255,.10);
  backdrop-filter: blur(18rpx);
}

.login-btn,
.dark-btn,
.submit-btn {
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(22,119,255,.14);
}

.status-entry {
  border-color: rgba(22,119,255,.14);
  border-radius: 26rpx;
  background: #ffffff;
}

.status-entry.active {
  border-color: transparent;
  background: linear-gradient(135deg, rgba(22,119,255,.12), rgba(54,207,201,.12));
  box-shadow: 0 14rpx 34rpx rgba(22,119,255,.14);
}

.status-icon,
.status-entry.active .status-icon,
.status-badge,
.status-entry.active .status-badge,
.recommend-badge {
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  color: #fff;
}

.status,
.amount,
.recommend-price {
  color: #ff6b35;
  font-weight: 950;
}

.order-cover,
.recommend-cover {
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .75), transparent 22%),
    linear-gradient(135deg, #dcecff, #36cfc9 52%, #1677ff);
}

.light-btn,
.upload-btn,
.cancel-btn {
  background: #eef6ff;
  color: #1677ff;
}

input,
textarea {
  border-color: rgba(22,119,255,.16);
  border-radius: 22rpx;
  background: #ffffff;
}

/* Runtime theme variables */
.orders-page {
  background: linear-gradient(180deg, var(--page-top-color, #f4f9ff) 0%, #ffffff 50%, var(--page-bottom-color, #ffffff) 100%);
}

.order-count,
.login-card,
.status-panel,
.order-card,
.empty-box,
.recommend-card,
.refund-panel {
  border-radius: var(--card-radius, 28rpx);
  background: var(--card-color, rgba(255,255,255,.86));
  box-shadow: 0 18rpx 48rpx var(--theme-shadow, rgba(22,119,255,.10));
}

.login-btn,
.dark-btn,
.submit-btn,
.status-icon,
.status-entry.active .status-icon,
.status-badge,
.recommend-badge {
  border-radius: var(--button-radius, 999rpx);
  background: linear-gradient(135deg, var(--button-start, #1677ff), var(--button-end, #36cfc9));
}

.eyebrow,
.light-btn,
.upload-btn,
.cancel-btn {
  color: var(--accent-color, #1677ff);
}

.page-title,
.login-title,
.section-title,
.product-name,
.empty-text,
.recommend-name,
.refund-title {
  color: var(--text-color, #1f2937);
}

.login-desc,
.section-subtitle,
.muted,
.empty-subtext,
.recommend-meta {
  color: var(--muted-color, #6b7280);
}

.status,
.amount,
.recommend-price {
  color: var(--price-color, #ff6b35);
}

.light-btn,
.upload-btn,
.cancel-btn {
  background: var(--soft-color, #eef6ff);
}
