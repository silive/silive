<view class="orders-page {{themeClass}}" style="{{themeStyle}}">
  <view class="page-head">
    <view>
      <view class="eyebrow">ORDER CENTER</view>
      <view class="page-title">订单</view>
    </view>
    <view class="order-count">{{orders.length}} 单</view>
  </view>

  <view wx:if="{{!loggedIn}}" class="login-card" style="{{cardStyle}}">
    <view class="login-copy">
      <view class="login-title">登录后查看订单</view>
      <view class="login-desc" style="{{mutedTextStyle}}">同步订单进度、物流与售后服务</view>
    </view>
    <view class="login-action-block">
      <button class="login-btn" style="{{primaryButtonStyle}}" catchtap="showLoginSheet">手机号快捷登录</button>
      <view class="orders-login-agreement">
        登录即表示你已阅读并同意
        <navigator class="protocol-link" url="/pages/agreement/service">《用户服务协议》</navigator>
        和
        <navigator class="protocol-link" url="/pages/agreement/privacy">《隐私政策》</navigator>
      </view>
    </view>
  </view>

  <view wx:if="{{loggedIn}}" class="status-panel">
    <view class="status-row top-row">
      <button class="status-entry {{activeStatus === item.key ? 'active' : ''}}" wx:for="{{statusTabsTop}}" wx:key="key" bindtap="switchStatus" data-key="{{item.key}}">
        <view class="status-icon">{{item.icon}}</view>
        <view class="status-name">{{item.label}}</view>
        <view wx:if="{{item.key !== 'afterSale'}}" class="status-badge">{{item.count}}</view>
      </button>
    </view>
    <view class="status-row bottom-row">
      <button class="status-entry {{activeStatus === item.key ? 'active' : ''}}" wx:for="{{statusTabsBottom}}" wx:key="key" bindtap="switchStatus" data-key="{{item.key}}">
        <view class="status-icon">{{item.icon}}</view>
        <view class="status-name">{{item.label}}</view>
        <view wx:if="{{item.key !== 'afterSale'}}" class="status-badge">{{item.count}}</view>
      </button>
    </view>
  </view>

  <view wx:if="{{loggedIn}}" class="section-head">
    <view class="section-title">订单列表</view>
    <view class="section-subtitle">{{totalFilteredOrders ? '共 ' + totalFilteredOrders + ' 单' : ''}}</view>
  </view>

  <view wx:if="{{loggedIn && recentOrders.length}}" class="order-list">
    <view class="order-card" style="{{cardStyle}}" wx:for="{{recentOrders}}" wx:key="id">
      <view class="order-main">
        <view class="order-cover cover-{{item.product.cover}}" bindtap="openOrderProduct" data-index="{{index}}">
          <image wx:if="{{item.productImage}}" class="order-image" src="{{item.productImage}}" mode="aspectFill" lazy-load />
          <view wx:else class="order-placeholder">非常智造</view>
        </view>
        <view class="order-info">
          <view class="order-head">
            <view class="product-name" bindtap="openOrderProduct" data-index="{{index}}">{{item.productName}}</view>
            <view class="status" style="{{tagStyle}}">{{item.displayStatus}}</view>
          </view>
          <view class="muted" style="{{mutedTextStyle}}">{{item.createdAtDisplay}}</view>
          <view class="pickup-info" wx:if="{{item.pickupLine}}">
            <view class="pickup-code">{{item.pickupLine}}</view>
            <view wx:if="{{item.canShowPickupCredential && item.pickupQrCodeUrl}}" class="pickup-qrcode-box">
              <image class="pickup-qrcode" src="{{item.pickupQrCodeUrl}}" mode="aspectFit" show-menu-by-longpress="true" />
              <view>
                <view class="pickup-code-large">{{item.pickupCode}}</view>
                <view class="muted" style="{{mutedTextStyle}}">向店员出示二维码</view>
              </view>
            </view>
            <view class="muted" style="{{mutedTextStyle}}">{{item.pickupTip}}</view>
            <view class="muted" style="{{mutedTextStyle}}" wx:if="{{item.pickupStore.address}}">{{item.pickupStore.address}}</view>
          </view>
          <view class="muted" style="{{mutedTextStyle}}" wx:if="{{item.shippingCompany || item.trackingNumber}}">物流：{{item.shippingCompany}} · {{item.trackingNumber}}</view>
          <view class="muted" style="{{mutedTextStyle}}" wx:if="{{item.refundLine}}">售后：{{item.refundLine}}</view>
          <view class="muted reject-reason" wx:if="{{item.afterSalesRejectReason}}">拒绝原因：{{item.afterSalesRejectReason}}</view>
          <view class="amount" style="{{priceStyle}}">{{item.isQuoteOrder ? '待报价' : ('¥' + item.amount)}}</view>
        </view>
      </view>
      <view class="actions">
        <button wx:if="{{item.canPay}}" class="dark-btn" style="{{primaryButtonStyle}}" bindtap="payOrder" data-index="{{index}}" loading="{{payLoadingOrderId == item.id}}">立即支付</button>
        <button wx:if="{{item.isQuoteOrder}}" class="dark-btn waiting-btn" disabled>等待报价</button>
        <button wx:if="{{item.canViewDetail}}" class="light-btn" style="{{secondaryButtonStyle}}" bindtap="openOrderProduct" data-index="{{index}}">查看详情</button>
        <button wx:if="{{item.canShowPickupCode}}" class="dark-btn" style="{{primaryButtonStyle}}" bindtap="showPickupCode" data-index="{{index}}">查看取货码</button>
        <button wx:if="{{item.canConfirmReceive}}" class="dark-btn" style="{{primaryButtonStyle}}" bindtap="confirmReceive" data-index="{{index}}">确认收货</button>
        <button wx:if="{{item.isRefundingOrder}}" class="light-btn" style="{{secondaryButtonStyle}}" bindtap="viewAfterSale" data-index="{{index}}">查看售后</button>
        <button wx:if="{{item.canContact || item.isQuoteOrder}}" class="light-btn" style="{{secondaryButtonStyle}}" open-type="contact" data-index="{{index}}">联系客服</button>
        <button wx:if="{{item.isUnpaidOrder || item.displayStatus === '已完成' || item.displayStatus === '已退款' || item.displayStatus === '已自提'}}" class="light-btn" style="{{secondaryButtonStyle}}" bindtap="reorder" data-index="{{index}}">再次下单</button>
        <button wx:if="{{item.canReapplyAfterSales}}" class="light-btn" style="{{secondaryButtonStyle}}" bindtap="openRefund" data-index="{{index}}" data-type="仅退款">重新申请售后</button>
        <button wx:elif="{{item.canRefund}}" class="light-btn" style="{{secondaryButtonStyle}}" bindtap="openRefund" data-index="{{index}}" data-type="仅退款">申请售后</button>
      </view>
    </view>
  </view>

  <button wx:if="{{loggedIn && hasMoreOrders}}" class="load-more-btn" bindtap="loadMoreOrders">
    加载更多订单
  </button>
  <view wx:elif="{{loggedIn && recentOrders.length}}" class="no-more-text">没有更多订单了</view>

  <view wx:elif="{{loggedIn}}" class="empty-box">
    <view class="empty-text">{{activeStatus === 'afterSale' ? '暂无可售后订单' : '暂无相关订单'}}</view>
    <view class="empty-subtext">可以先看看下方推荐商品</view>
  </view>

  <view class="section-head recommend-head">
    <view>
      <view class="section-title">猜你喜欢</view>
      <view class="section-subtitle" style="{{mutedTextStyle}}">根据历史订单与热卖商品推荐</view>
    </view>
  </view>

  <view class="recommend-grid">
    <view class="recommend-card" style="{{cardStyle}}" wx:for="{{recommendations}}" wx:key="id" bindtap="openRecommendProduct" data-index="{{index}}">
      <view class="recommend-cover cover-{{item.cover}}">
        <image wx:if="{{item.imageUrl}}" class="recommend-image" src="{{item.imageUrl}}" mode="aspectFill" lazy-load />
        <view wx:if="{{item.badgeText}}" class="recommend-badge">{{item.badgeText}}</view>
      </view>
      <view class="recommend-name">{{item.name}}</view>
      <view class="recommend-meta" style="{{mutedTextStyle}}">{{item.recommendReason}}</view>
      <view class="recommend-price" style="{{priceStyle}}">¥{{item.price}}</view>
    </view>
  </view>

  <view class="refund-mask" wx:if="{{refundVisible}}">
    <view class="refund-panel">
      <view class="refund-title">申请售后</view>
      <scroll-view class="refund-body" scroll-y>
        <picker mode="selector" range="{{afterSalesTypes}}" bindchange="onAfterSalesTypeChange">
          <view class="field picker-field">售后类型<text>{{refundForm.afterSalesType}}</text></view>
        </picker>
        <view class="field">售后原因<textarea value="{{refundForm.afterSalesReason}}" data-field="afterSalesReason" bindinput="onRefundInput" placeholder="请填写售后原因"></textarea></view>
        <view class="field">问题说明<textarea value="{{refundForm.afterSalesDesc}}" data-field="afterSalesDesc" bindinput="onRefundInput" placeholder="补充说明问题现象、处理诉求"></textarea></view>
        <view class="field">联系电话<input value="{{refundForm.contactPhone}}" data-field="contactPhone" bindinput="onRefundInput" type="number" placeholder="请填写联系电话" /></view>
        <button class="upload-btn" style="{{secondaryButtonStyle}}" bindtap="chooseRefundImage">上传图片凭证（最多6张）</button>
        <view class="refund-images" wx:if="{{refundForm.afterSalesImages.length}}">
          <view class="refund-image-wrap" wx:for="{{refundForm.afterSalesImages}}" wx:key="*this">
            <image class="refund-image" src="{{item}}" mode="aspectFill" />
            <button class="refund-remove" bindtap="removeRefundImage" data-index="{{index}}">×</button>
          </view>
        </view>
        <view class="muted refund-note" style="{{mutedTextStyle}}">提交后进入后台审核，不会自动退款。</view>
      </scroll-view>
      <view class="modal-actions refund-footer">
        <button class="cancel-btn" style="{{secondaryButtonStyle}}" bindtap="closeRefund">取消</button>
        <button class="submit-btn" style="{{primaryButtonStyle}}" bindtap="submitRefund" loading="{{submittingRefund}}">提交申请</button>
      </view>
    </view>
  </view>

  <login-sheet
    visible="{{loginVisible}}"
    loading="{{loginLoading}}"
    title="手机号快捷登录"
    desc="我们将申请获取并验证你的手机号，用于订单确认、配送联系、售后服务及账号身份识别。未经你同意，不会用于其他无关用途。"
    confirm-text="手机号快捷登录"
    cancel-text="暂不登录"
    bind:getphonenumber="onLoginPhone"
    bind:close="closeLoginSheet"
  />
</view>
