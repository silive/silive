.profile-page {
  min-height: 100vh;
  padding: 36rpx 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f4f9ff 0%, #ffffff 52%, #eef6ff 100%);
}

.user-card {
  display: grid;
  grid-template-columns: 104rpx minmax(0, 1fr) 220rpx;
  gap: 20rpx;
  align-items: center;
  padding: 26rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.user-info {
  min-width: 0;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.placeholder {
  background: #1f2937;
  color: #f8fbff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 850;
}

.user-name {
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 850;
}

.user-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.auth-btn {
  height: 58rpx;
  min-width: 112rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #e6f7ff;
  color: #24302d;
  font-size: 23rpx;
  font-weight: 850;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn {
  justify-self: end;
  width: 176rpx;
  min-width: 176rpx;
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dcebff;
  background: #ffffff;
  color: #1677ff;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 64rpx;
  text-align: center;
  white-space: nowrap;
  box-sizing: border-box;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, .08);
}

.avatar-btn::after {
  border: 0;
}

.avatar-btn:active {
  background: #eef6ff;
  transform: scale(.98);
}

.login-auth-btn {
  width: 220rpx;
  height: 72rpx;
  padding: 0 28rpx;
  background: #1f2937;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  box-sizing: border-box;
  white-space: nowrap;
  transition: transform .16s ease, opacity .16s ease;
}

.login-auth-btn:active {
  opacity: .86;
  transform: scale(.98);
}

.wallet-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
  padding: 26rpx;
  border-radius: 22rpx;
  background: #1f2937;
  color: #f8fbff;
  box-shadow: 0 18rpx 42rpx rgba(32, 32, 32, .16);
}

.wallet-label {
  color: rgba(255, 246, 239, .72);
  font-size: 23rpx;
  font-weight: 800;
}

.wallet-value {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 850;
}

.wallet-pending {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .12);
  font-size: 22rpx;
  font-weight: 800;
}

.store-entry-card {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 34rpx;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, .9);
  border: 1rpx solid rgba(22,119,255,.14);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.store-entry-card:active {
  transform: scale(.985);
  background: #eef6ff;
}

.store-entry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #eef6ff, #e6f4ff);
  color: #1677ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 950;
}

.store-entry-main {
  min-width: 0;
}

.store-entry-title {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 950;
}

.store-entry-subtitle {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
  font-weight: 700;
}

.store-entry-meta {
  display: inline-flex;
  margin-top: 12rpx;
  max-width: 100%;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 125, 116, .12);
  color: #1677ff;
  font-size: 20rpx;
  font-weight: 850;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.store-entry-arrow {
  color: #b9aaa6;
  font-size: 40rpx;
  font-weight: 500;
  text-align: right;
}

.feature-panel {
  margin-top: 28rpx;
  padding: 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, .9);
  box-shadow: 0 14rpx 36rpx rgba(83, 69, 64, .08);
}

.feature-row {
  display: flex;
  justify-content: center;
  gap: 18rpx;
}

.feature-row + .feature-row {
  margin-top: 18rpx;
}

.top-row .feature-card {
  width: 30%;
}

.bottom-row .feature-card {
  width: 45%;
}

.feature-card {
  position: relative;
  height: 164rpx;
  padding: 20rpx 10rpx 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  color: #1f2937;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #dcebff;
  box-sizing: border-box;
  flex-shrink: 0;
  box-shadow: 0 8rpx 22rpx rgba(83, 69, 64, .05);
}

.feature-card:active {
  background: #e6f4ff;
  transform: scale(.985);
}

.feature-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #eef6ff;
  color: #5f5753;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1;
}

.feature-title {
  margin-top: 14rpx;
  color: #1f2937;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
}

.feature-subtitle {
  margin-top: 7rpx;
  color: #6b7280;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.feature-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  min-width: 38rpx;
  height: 38rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #1f2937;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 19rpx;
  font-weight: 900;
}

.online-pill {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  background: #1f2937;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 900;
}

.red-dot {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #1677ff;
  box-shadow: 0 0 0 6rpx rgba(211, 95, 85, .12);
}

.profile-banner {
  position: relative;
  display: block;
  height: 230rpx;
  margin-top: 26rpx;
  padding: 0;
  border-radius: 24rpx;
  overflow: hidden;
  background: #1f2937;
  box-shadow: 0 18rpx 42rpx rgba(32, 32, 32, .14);
  text-align: left;
  line-height: normal;
}

.profile-banner::after {
  border: 0;
}

.profile-banner-image {
  width: 100%;
  height: 100%;
  opacity: .82;
}

.profile-banner-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(31,41,55,.72), rgba(22,119,255,.08));
}

.profile-banner-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 26rpx;
  color: #ffffff;
}

.profile-banner-tag {
  display: inline-flex;
  margin-bottom: 10rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .18);
  font-size: 18rpx;
  font-weight: 900;
}

.profile-banner-title {
  font-size: 31rpx;
  font-weight: 900;
}

.profile-banner-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: .88;
}

.copyright {
  margin-top: 34rpx;
  background: transparent;
  color: #aaa19d;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.6;
  text-align: center;
}

/* Youth brand visual refresh */
.profile-page {
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 126, 159, .18), transparent 28%),
    linear-gradient(180deg, #f4f9ff 0%, #ffffff 50%, #ffffff 100%);
  animation: pageFade .34s ease both;
}

@keyframes pageFade {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.user-card,
.feature-panel {
  border: 1rpx solid rgba(22,119,255,.14);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, .86);
  box-shadow: 0 18rpx 48rpx rgba(22,119,255,.10);
  backdrop-filter: blur(18rpx);
}

.placeholder,
.login-auth-btn,
.feature-badge,
.online-pill {
  background: linear-gradient(135deg, #1677ff, #36cfc9);
  color: #fff;
  box-shadow: 0 14rpx 30rpx rgba(22,119,255,.14);
}

.auth-btn {
  background: #eef6ff;
  color: #1677ff;
}

.user-name,
.feature-title,
.profile-banner-title {
  color: #1f2937;
  font-weight: 950;
}

.user-desc,
.feature-subtitle,
.copyright {
  color: #6b7280;
}

.wallet-card {
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 86% 0%, rgba(255, 255, 255, .24), transparent 30%),
    linear-gradient(135deg, #1f2937 0%, #36cfc9 100%);
  box-shadow: 0 24rpx 56rpx rgba(22,119,255,.13);
}

.feature-card {
  border-color: rgba(22,119,255,.14);
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(22,119,255,.08);
}

.feature-card:active {
  background: #eef6ff;
}

.feature-icon {
  background: linear-gradient(135deg, #eef6ff, #e6f4ff);
  color: #1677ff;
}

.red-dot {
  background: #ef4444;
  box-shadow: 0 0 0 6rpx rgba(255, 95, 109, .14);
}

.profile-banner {
  border-radius: 30rpx;
  box-shadow: 0 24rpx 56rpx rgba(22,119,255,.14);
}

.profile-banner-mask {
  background: linear-gradient(90deg, rgba(31,41,55,.72), rgba(22,119,255,.10));
}

.profile-banner-copy,
.profile-banner-title {
  color: #fff;
}

/* Runtime theme variables */
.profile-page {
  background: linear-gradient(180deg, var(--page-top-color, #f4f9ff) 0%, #ffffff 50%, var(--page-bottom-color, #ffffff) 100%);
}

.user-card,
.feature-panel {
  border-radius: var(--card-radius, 30rpx);
  background: var(--card-color, rgba(255,255,255,.86));
  box-shadow: 0 18rpx 48rpx var(--theme-shadow, rgba(22,119,255,.10));
}

.placeholder,
.login-auth-btn,
.feature-badge,
.online-pill {
  border-radius: var(--button-radius, 999rpx);
  background: linear-gradient(135deg, var(--button-start, #1677ff), var(--button-end, #36cfc9));
}

.wallet-card {
  background:
    radial-gradient(circle at 86% 0%, rgba(255, 255, 255, .24), transparent 30%),
    linear-gradient(135deg, var(--button-start, #1f2937), var(--button-end, #36cfc9));
  box-shadow: 0 24rpx 56rpx var(--theme-shadow, rgba(22,119,255,.13));
}

.auth-btn,
.feature-icon {
  background: var(--soft-color, #eef6ff);
  color: var(--accent-color, #1677ff);
}

.avatar-btn {
  background: #ffffff;
  color: var(--accent-color, #1677ff);
  border-color: var(--border-color, #dcebff);
}

.user-name,
.feature-title {
  color: var(--text-color, #1f2937);
}

.user-desc,
.feature-subtitle,
.copyright {
  color: var(--muted-color, #6b7280);
}
