<view class="profile-page {{themeClass}}" style="{{themeStyle}}">
  <view class="user-card" style="{{cardStyle}}">
    <image wx:if="{{userInfo.avatarUrl}}" class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar placeholder">我</view>
    <view class="user-info">
      <view class="user-name">{{loggedIn ? (userInfo.nickName || '用户') : '欢迎来到非常智造'}}</view>
      <view class="user-desc" style="{{mutedTextStyle}}">{{loggedIn ? ('手机号 ' + maskedPhone) : '登录后同步订单、地址与会员权益'}}</view>
    </view>
    <button wx:if="{{loggedIn}}" class="auth-btn avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">更换头像</button>
    <button wx:else class="auth-btn login-auth-btn" style="{{primaryButtonStyle}}" bindtap="showLoginSheet">手机号快捷登录</button>
  </view>
  <view wx:if="{{!loggedIn}}" class="profile-login-agreement">
    登录即表示你已阅读并同意
    <navigator class="protocol-link" url="/pages/agreement/service">《用户服务协议》</navigator>
    和
    <navigator class="protocol-link" url="/pages/agreement/privacy">《隐私政策》</navigator>
  </view>

  <view wx:if="{{promotionEnabled && loggedIn}}" class="wallet-card" style="{{walletCardStyle}}">
    <view>
      <view class="wallet-label">推广奖励</view>
      <view class="wallet-value">¥{{actualPayable || pendingReward || '0.00'}}</view>
    </view>
    <view>
      <view class="wallet-pending">当前待结算 ¥{{pendingReward}}</view>
      <view class="wallet-note">本次预计到账，平台人工审核后结算</view>
    </view>
  </view>
  <view wx:elif="{{promotionEnabled && !loggedIn}}" class="reward-login-tip" style="{{cardStyle}}">
    登录后查看推荐奖励和订单进度
  </view>

  <view class="feature-panel">
    <view class="feature-row top-row">
      <button class="feature-card" style="{{cardStyle}}" bindtap="goOrders">
        <view wx:if="{{orderCount > 0}}" class="feature-badge">{{orderCount}}</view>
        <view class="feature-icon" style="{{iconBadgeStyle}}">≡</view>
        <view class="feature-title">我的订单</view>
        <view class="feature-subtitle" style="{{mutedTextStyle}}">查看进度</view>
      </button>
      <block wx:if="{{promotionEnabled || storeFeaturesEnabled}}">
        <button wx:if="{{storeFeaturesEnabled && loggedIn && storeBound}}" class="feature-card" style="{{cardStyle}}" bindtap="goStoreCenter">
          <view class="feature-icon" style="{{iconBadgeStyle}}">店</view>
          <view class="feature-title">门店中心</view>
          <view class="feature-subtitle" style="{{mutedTextStyle}}">订单与收益</view>
        </button>
        <button wx:elif="{{storeFeaturesEnabled && loggedIn && storeConflictMessage}}" class="feature-card" style="{{cardStyle}}">
          <view class="feature-icon" style="{{iconBadgeStyle}}">!</view>
          <view class="feature-title">门店异常</view>
          <view class="feature-subtitle" style="{{mutedTextStyle}}">{{storeConflictMessage}}</view>
        </button>
        <button wx:if="{{promotionEnabled}}" class="feature-card" style="{{cardStyle}}" bindtap="goPromotion">
          <view class="feature-icon" style="{{iconBadgeStyle}}">¥</view>
          <view class="feature-title">我的推广</view>
          <view class="feature-subtitle" style="{{mutedTextStyle}}">分享好物</view>
        </button>
      </block>
      <button class="feature-card" style="{{cardStyle}}" open-type="contact">
        <view wx:if="{{contact.showWorkWechat !== 'false'}}" class="online-pill">在线</view>
        <view class="feature-icon" style="{{iconBadgeStyle}}">☎</view>
        <view class="feature-title">联系客服</view>
        <view class="feature-subtitle" style="{{mutedTextStyle}}">1对1服务</view>
      </button>
    </view>
    <view class="feature-row bottom-row">
      <button class="feature-card" style="{{cardStyle}}" bindtap="goHelp">
        <view wx:if="{{afterSaleDot}}" class="red-dot"></view>
        <view class="feature-icon" style="{{iconBadgeStyle}}">✓</view>
        <view class="feature-title">售后保障</view>
        <view class="feature-subtitle" style="{{mutedTextStyle}}">退款/售后说明</view>
      </button>
    </view>
  </view>
  <button wx:if="{{banner && banner.imageUrl && (banner.targetType === 'contact' || banner.linkType === 'contact')}}" class="profile-banner" style="{{bannerStyle}}" open-type="contact">
    <image class="profile-banner-image" src="{{banner.imageUrl}}" mode="aspectFill" />
    <view class="profile-banner-copy">
      <view wx:if="{{banner.tag}}" class="profile-banner-tag">{{banner.tag}}</view>
      <view class="profile-banner-title">{{banner.title}}</view>
      <view class="profile-banner-desc">{{banner.desc}}</view>
    </view>
  </button>
  <view wx:elif="{{banner && banner.imageUrl}}" class="profile-banner" style="{{bannerStyle}}" bindtap="openBanner">
    <image class="profile-banner-image" src="{{banner.imageUrl}}" mode="aspectFill" />
    <view class="profile-banner-copy">
      <view wx:if="{{banner.tag}}" class="profile-banner-tag">{{banner.tag}}</view>
      <view class="profile-banner-title">{{banner.title}}</view>
      <view class="profile-banner-desc">{{banner.desc}}</view>
    </view>
  </view>
  <button class="copyright" bindtap="goHelp">本程序由 非常智造 开发与维护</button>

  <login-sheet
    visible="{{loginVisible}}"
    loading="{{loginLoading}}"
    title="手机号快捷登录"
    desc="我们将申请获取并验证你的手机号，用于订单确认、配送联系、售后服务及账号身份识别。未经你同意，不会用于其他无关用途。"
    confirm-text="手机号快捷登录"
    cancel-text="暂不登录"
    bind:getphonenumber="onLoginPhone"
    bind:close="closeLoginSheet"
  />
</view>
