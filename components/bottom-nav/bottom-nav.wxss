.bottom-nav {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 1100;
  min-height: 112rpx;
  padding: 12rpx 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 46rpx rgba(255, 106, 0, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-sizing: border-box;
  backdrop-filter: blur(18rpx);
}

.nav-item {
  flex: 1;
  height: 88rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 24rpx;
  background: transparent;
  color: #8b95a5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
  box-sizing: border-box;
}

.nav-item::after {
  border: 0;
}

.nav-item.active {
  color: #FF5A00;
  background: #FFF3E8;
}

.nav-icon {
  height: 34rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 34rpx;
}

.nav-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 850;
}
